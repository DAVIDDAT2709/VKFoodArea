<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Plugin.Maui.Audio</id>
    <version>4.0.0</version>
    <title>.NET MAUI Audio Plugin</title>
    <authors>bijington,jfversluis</authors>
    <requireLicenseAcceptance>true</requireLicenseAcceptance>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <icon>icon.png</icon>
    <readme>README.md</readme>
    <projectUrl>https://github.com/jfversluis/Plugin.Maui.Audio</projectUrl>
    <description>Plugin.Maui.Audio provides the ability to play and record audio inside a .NET MAUI application.</description>
    <copyright>Copyright © bijington, jfversluis and contributors</copyright>
    <tags>dotnet-maui maui audio sound play record</tags>
    <repository type="git" url="https://github.com/jfversluis/Plugin.Maui.Audio" commit="931337eecb5bc3895262b035b69e82a56c5ea8ce" />
    <dependencies>
      <group targetFramework="net9.0">
        <dependency id="Microsoft.Maui.Controls" version="4.0.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net9.0-android35.0">
        <dependency id="Microsoft.Maui.Controls" version="4.0.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net9.0-ios18.0">
        <dependency id="Microsoft.Maui.Controls" version="4.0.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net9.0-maccatalyst18.0">
        <dependency id="Microsoft.Maui.Controls" version="4.0.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net9.0-windows10.0.19041">
        <dependency id="Microsoft.Maui.Controls" version="4.0.0" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>