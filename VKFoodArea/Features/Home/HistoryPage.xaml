<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="VKFoodArea.Features.Home.HistoryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:VKFoodArea.Features.Home"
    x:DataType="local:HistoryPage"
    Title="Lịch sử nghe"
    BackgroundColor="#FFFFFF">

	<Grid RowDefinitions="Auto,*" Padding="16">

		<VerticalStackLayout Grid.Row="0" Spacing="12">
			<Label Text="Lịch sử nghe"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="#111827" />

			<Label Text="{Binding SummaryText}"
                   FontSize="14"
                   TextColor="#6B7280" />

			<Grid ColumnDefinitions="*,*" ColumnSpacing="10">
				<Button Grid.Column="0"
                        Text="Làm mới"
                        Clicked="OnRefreshClicked"
                        BackgroundColor="#111827"
                        TextColor="White"
                        CornerRadius="14" />

				<Button Grid.Column="1"
                        Text="Xóa lịch sử"
                        Clicked="OnClearClicked"
                        BackgroundColor="#DC2626"
                        TextColor="White"
                        CornerRadius="14" />
			</Grid>
		</VerticalStackLayout>

		<CollectionView Grid.Row="1"
                        Margin="0,16,0,0"
                        ItemsSource="{Binding Items}"
                        SelectionMode="None">

			<CollectionView.EmptyView>
				<Border Stroke="#E5E7EB"
                        BackgroundColor="#F9FAFB"
                        Padding="18">
					<Border.StrokeShape>
						<RoundRectangle CornerRadius="16" />
					</Border.StrokeShape>

					<VerticalStackLayout Spacing="8">
						<Label Text="Chưa có lịch sử nghe"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#111827" />

						<Label Text="Khi bạn nghe thuyết minh ở trang chủ, bản đồ hoặc trang chi tiết, dữ liệu sẽ hiện ở đây."
                               FontSize="14"
                               TextColor="#6B7280" />
					</VerticalStackLayout>
				</Border>
			</CollectionView.EmptyView>

			<CollectionView.ItemTemplate>
				<DataTemplate x:DataType="local:HistoryItemViewModel">
					<Border Stroke="#E5E7EB"
                            BackgroundColor="White"
                            Padding="14"
                            Margin="0,0,0,10">
						<Border.StrokeShape>
							<RoundRectangle CornerRadius="16" />
						</Border.StrokeShape>

						<VerticalStackLayout Spacing="6">
							<Label Text="{Binding PoiName}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#111827" />

							<Label Text="{Binding PlayedAtText}"
                                   FontSize="13"
                                   TextColor="#6B7280" />

							<Label Text="{Binding MetaText}"
                                   FontSize="13"
                                   TextColor="#7C3AED" />
						</VerticalStackLayout>
					</Border>
				</DataTemplate>
			</CollectionView.ItemTemplate>

		</CollectionView>

	</Grid>
</ContentPage>