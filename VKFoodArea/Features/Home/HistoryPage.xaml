<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="VKFoodArea.Features.Home.HistoryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:VKFoodArea.Features.Home"
    x:DataType="local:HistoryPage"
    Title=""
    BackgroundColor="#EEF4F1"
    NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto,*,Auto"
          Padding="16,12,16,16">
        <Border Grid.Row="0"
                Padding="18,18,18,20"
                StrokeThickness="0">
            <Border.Background>
                <LinearGradientBrush EndPoint="1,1">
                    <GradientStop Color="#0E9A91" Offset="0.0" />
                    <GradientStop Color="#38C3B4" Offset="0.58" />
                    <GradientStop Color="#7BE8D1" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="30" />
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="14">
                <Label x:Name="HeaderTitleLabel"
                       FontSize="27"
                       FontAttributes="Bold"
                       FontFamily="OpenSansSemibold"
                       TextColor="White" />
                <Label Text="{Binding SummaryText}"
                       FontSize="14"
                       TextColor="#E8FFFC" />
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="10">
                    <Button Grid.Column="0"
                            x:Name="RefreshButton"
                            Clicked="OnRefreshClicked"
                            BackgroundColor="#EEFFFFFF"
                            TextColor="#0E625C"
                            CornerRadius="16"
                            FontAttributes="Bold" />
                    <Button Grid.Column="1"
                            x:Name="ClearButton"
                            Clicked="OnClearClicked"
                            BackgroundColor="#1E102021"
                            TextColor="White"
                            CornerRadius="16"
                            FontAttributes="Bold" />
                </Grid>
            </VerticalStackLayout>
        </Border>

        <CollectionView Grid.Row="1"
                        Margin="0,16,0,0"
                        ItemsSource="{Binding Items}"
                        SelectionMode="None">
            <CollectionView.EmptyView>
                <Border BackgroundColor="White"
                        Stroke="#D7E4DF"
                        StrokeThickness="1"
                        Padding="20"
                        StrokeShape="RoundRectangle 24">
                    <VerticalStackLayout Spacing="10">
                        <Label x:Name="EmptyTitleLabel"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="#163632" />
                        <Label x:Name="EmptyMessageLabel"
                               FontSize="14"
                               TextColor="#66817B" />
                    </VerticalStackLayout>
                </Border>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="local:HistoryItemViewModel">
                    <Border BackgroundColor="White"
                            Stroke="#D7E4DF"
                            StrokeThickness="1"
                            Padding="14"
                            Margin="0,0,0,10"
                            StrokeShape="RoundRectangle 22">
                        <Border.Shadow>
                            <Shadow Brush="#8FAAA3"
                                    Offset="0,10"
                                    Radius="16"
                                    Opacity="0.10" />
                        </Border.Shadow>
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="12">
                            <Border WidthRequest="42"
                                    HeightRequest="42"
                                    BackgroundColor="#DDF7F1"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 21">
                                <Label Text="♪"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       FontSize="18"
                                       TextColor="#139587" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="4">
                                <Label Text="{Binding PoiName}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#163632" />
                                <Label Text="{Binding PlayedAtText}"
                                       FontSize="13"
                                       TextColor="#6C8781" />
                                <Border BackgroundColor="#F4FBF8"
                                        Padding="10,6"
                                        StrokeThickness="0"
                                        HorizontalOptions="Start"
                                        StrokeShape="RoundRectangle 12">
                                    <Label Text="{Binding MetaText}"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="#169488" />
                                </Border>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Border Grid.Row="2"
                Margin="0,14,0,0"
                BackgroundColor="White"
                Stroke="#D8E2DE"
                StrokeThickness="1"
                Padding="8"
                StrokeShape="RoundRectangle 22">
            <Grid ColumnDefinitions="*,*,*,*"
                  ColumnSpacing="6">
                <Button x:Name="NavHomeButton" Grid.Column="0" Clicked="OnGoHomeClicked" BackgroundColor="Transparent" TextColor="#708682" FontSize="11" Padding="4,8" ImageSource="nav_home.svg" ContentLayout="Top,4" />
                <Button x:Name="NavMapButton" Grid.Column="1" Clicked="OnOpenFullMapClicked" BackgroundColor="Transparent" TextColor="#708682" FontSize="11" Padding="4,8" ImageSource="nav_map.svg" ContentLayout="Top,4" />
                <Border Grid.Column="2" BackgroundColor="#DDF7F1" StrokeThickness="0" StrokeShape="RoundRectangle 18"><Button x:Name="NavHistoryButton" Clicked="OnHistoryClickedCurrent" BackgroundColor="Transparent" TextColor="#159487" FontSize="11" FontAttributes="Bold" Padding="4,8" ImageSource="nav_history.svg" ContentLayout="Top,4" /></Border>
                <Button x:Name="NavAccountButton" Grid.Column="3" Clicked="OnUserClicked" BackgroundColor="Transparent" TextColor="#708682" FontSize="11" Padding="4,8" ImageSource="nav_account.svg" ContentLayout="Top,4" />
            </Grid>
        </Border>
    </Grid>
</ContentPage>

