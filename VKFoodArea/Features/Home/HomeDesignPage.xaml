<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="VKFoodArea.Features.Home.HomeDesignPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:home="clr-namespace:VKFoodArea.Features.Home"
    xmlns:viewModels="clr-namespace:VKFoodArea.Features.Home"
    xmlns:models="clr-namespace:VKFoodArea.Models"
    x:DataType="viewModels:HomeViewModel"
    BackgroundColor="#F5F7F6"
    Padding="0"
    NavigationPage.HasNavigationBar="False"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,208,*,Auto,Auto"
          BackgroundColor="#F5F7F6">

        <VerticalStackLayout Grid.Row="0"
                             Padding="16,14,16,10"
                             Spacing="10">
            <Grid ColumnDefinitions="*,Auto,Auto"
                  ColumnSpacing="8">
                <VerticalStackLayout Spacing="2"
                                     VerticalOptions="Center">
                    <Label Text="VKFoodArea"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#1F6F64" />
                    <Label x:Name="NearestPoiLabel"
                           Text="{Binding NearestPoiText}"
                           FontSize="12"
                           TextColor="#617A74"
                           LineBreakMode="TailTruncation"
                           MaxLines="1" />
                </VerticalStackLayout>

                <Button x:Name="QrButton"
                        Grid.Column="1"
                        Clicked="OnQrClicked"
                        WidthRequest="44"
                        HeightRequest="40"
                        CornerRadius="12"
                        BackgroundColor="#E6F3EF"
                        TextColor="#1F6F64"
                        FontSize="12"
                        FontAttributes="Bold" />

                <Button Grid.Column="2"
                        Text="⚙"
                        Clicked="OnSettingsClicked"
                        WidthRequest="40"
                        HeightRequest="40"
                        CornerRadius="12"
                        BackgroundColor="White"
                        TextColor="#48635F"
                        BorderColor="#D8E2DE"
                        BorderWidth="1"
                        FontSize="15" />
            </Grid>

            <Border BackgroundColor="White"
                    Stroke="#D8E2DE"
                    StrokeThickness="1"
                    Padding="8,0"
                    StrokeShape="RoundRectangle 16">
                <SearchBar x:Name="PoiSearchBar"
                           PlaceholderColor="#8AA09A"
                           TextColor="#173330"
                           BackgroundColor="Transparent"
                           CancelButtonColor="#1F6F64"
                           HeightRequest="40"
                           FontSize="13"
                           SearchButtonPressed="OnSearchButtonPressed"
                           TextChanged="OnSearchTextChanged" />
            </Border>

            <Border x:Name="SearchSuggestionContainer"
                    IsVisible="{Binding ShowSearchSuggestions}"
                    BackgroundColor="White"
                    Stroke="#D8E2DE"
                    StrokeThickness="1"
                    Padding="8"
                    StrokeShape="RoundRectangle 18">
                <CollectionView x:Name="SearchSuggestionCollectionView"
                                ItemsSource="{Binding SearchSuggestions}"
                                HeightRequest="{Binding SearchSuggestionHeight}"
                                SelectionMode="Single"
                                SelectionChanged="OnSuggestionSelected">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical"
                                           ItemSpacing="6" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="home:HomePoiSuggestion">
                            <Border BackgroundColor="#F7FAF9"
                                    StrokeThickness="0"
                                    Padding="12"
                                    StrokeShape="RoundRectangle 14">
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="{Binding Name}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="#173330"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="1" />

                                    <Label Text="{Binding Address}"
                                           FontSize="12"
                                           TextColor="#617A74"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="1" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>

            <Label x:Name="SearchEmptyStateLabel"
                   IsVisible="{Binding ShowSearchEmptyState}"
                   Text="{Binding SearchEmptyMessage}"
                   FontSize="12"
                   TextColor="#8C4B39"
                   Margin="4,0,4,0" />
        </VerticalStackLayout>

        <Grid Grid.Row="1"
              Margin="16,0,16,12">
            <Border BackgroundColor="White"
                    Stroke="#D8E2DE"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 22">
                <Border.Shadow>
                    <Shadow Brush="#122F2A"
                            Offset="0,10"
                            Radius="18"
                            Opacity="0.08" />
                </Border.Shadow>

                <Grid>
                    <ContentView x:Name="MapHost"
                                 HorizontalOptions="Fill"
                                 VerticalOptions="Fill" />

                    <Grid Padding="10"
                          RowDefinitions="*,Auto"
                          ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="8">
                            <Button Text="+"
                                    Clicked="OnZoomInClicked"
                                    WidthRequest="36"
                                    HeightRequest="36"
                                    CornerRadius="18"
                                    BackgroundColor="White"
                                    TextColor="#173330"
                                    BorderColor="#D8E2DE"
                                    BorderWidth="1"
                                    FontSize="18"
                                    FontAttributes="Bold" />

                            <Button Text="−"
                                    Clicked="OnZoomOutClicked"
                                    WidthRequest="36"
                                    HeightRequest="36"
                                    CornerRadius="18"
                                    BackgroundColor="White"
                                    TextColor="#173330"
                                    BorderColor="#D8E2DE"
                                    BorderWidth="1"
                                    FontSize="18"
                                    FontAttributes="Bold" />
                        </VerticalStackLayout>

                        <Button Grid.Row="0"
                                Grid.Column="1"
                                Text="⌖"
                                Clicked="OnOpenFullMapClicked"
                                WidthRequest="36"
                                HeightRequest="36"
                                CornerRadius="18"
                                HorizontalOptions="End"
                                VerticalOptions="End"
                                BackgroundColor="#EAF4F1"
                                TextColor="#1F6F64"
                                FontSize="15" />

                        <Border Grid.Row="1"
                                Grid.ColumnSpan="2"
                                BackgroundColor="#183A35"
                                StrokeThickness="0"
                                Padding="12,8"
                                StrokeShape="RoundRectangle 16">
                            <Label Text="{Binding StatusText}"
                                   FontSize="10.5"
                                   TextColor="#F2F8F6"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="1" />
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <CollectionView x:Name="PoiCollectionView"
                        Grid.Row="2"
                        ItemsSource="{Binding DisplayedPois}"
                        Margin="16,0,16,8"
                        SelectionMode="None">
            <CollectionView.Header>
                <VerticalStackLayout Margin="0,0,0,16"
                                     Spacing="16">
                    <VerticalStackLayout Spacing="10">
                        <Label x:Name="FeaturedFoodsTitleLabel"
                               FontSize="20"
                               FontAttributes="Bold"
                               FontFamily="OpenSansSemibold"
                               TextColor="#173330" />

                        <CollectionView x:Name="FeaturedFoodCollectionView"
                                        HeightRequest="154"
                                        SelectionMode="None">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal"
                                                   ItemSpacing="6"
                                                   SnapPointsType="MandatorySingle"
                                                   SnapPointsAlignment="Start" />
                            </CollectionView.ItemsLayout>

                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="home:FeaturedFoodCardViewModel">
                                    <Border WidthRequest="124"
                                            BackgroundColor="White"
                                            Stroke="#DDE6E2"
                                            StrokeThickness="1"
                                            Padding="0"
                                            StrokeShape="RoundRectangle 20">
                                        <Border.Shadow>
                                            <Shadow Brush="#12312B"
                                                    Offset="0,4"
                                                    Radius="10"
                                                    Opacity="0.04" />
                                        </Border.Shadow>

                                        <Grid RowDefinitions="72,Auto">
                                            <Border StrokeThickness="0">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="20,20,0,0" />
                                                </Border.StrokeShape>
                                                <Grid>
                                                    <Image Source="{Binding ImageUrl}"
                                                           Aspect="AspectFill" />

                                                    <Border Margin="8,0,8,8"
                                                            Padding="7,3"
                                                            HorizontalOptions="Start"
                                                            VerticalOptions="End"
                                                            BackgroundColor="#FFFBF2"
                                                            StrokeThickness="0"
                                                            StrokeShape="RoundRectangle 10">
                                                        <Label Text="{Binding PriceText}"
                                                               FontSize="9"
                                                               FontAttributes="Bold"
                                                               TextColor="#9C6A16"
                                                               LineBreakMode="TailTruncation"
                                                               MaxLines="1" />
                                                    </Border>
                                                </Grid>
                                            </Border>

                                            <VerticalStackLayout Grid.Row="1"
                                                                 Padding="10,8,10,10"
                                                                 Spacing="6">
                                                <Label Text="{Binding Name}"
                                                       FontSize="12.5"
                                                       FontAttributes="Bold"
                                                       TextColor="#173330"
                                                       LineBreakMode="WordWrap"
                                                       MaxLines="2" />

                                                <Border BackgroundColor="#EEF7F3"
                                                        Padding="8,4"
                                                        HorizontalOptions="Start"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 10">
                                                    <Label Text="{Binding RestaurantName}"
                                                           FontSize="9.5"
                                                           FontAttributes="Bold"
                                                           TextColor="#176B61"
                                                           LineBreakMode="TailTruncation"
                                                           MaxLines="1" />
                                                </Border>
                                            </VerticalStackLayout>
                                        </Grid>

                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnFeaturedFoodTapped" />
                                        </Border.GestureRecognizers>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="10">
                        <Label x:Name="FeaturedPoisTitleLabel"
                               FontSize="20"
                               FontAttributes="Bold"
                               FontFamily="OpenSansSemibold"
                               TextColor="#173330" />

                        <Button x:Name="HistoryActionButton"
                                Grid.Column="1"
                                Clicked="OnHistoryClicked"
                                BackgroundColor="#EAF4F1"
                                TextColor="#1F6F64"
                                FontSize="12"
                                FontAttributes="Bold"
                                Padding="14,8"
                                CornerRadius="16"
                                VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
            </CollectionView.Header>

            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical"
                                 Span="2"
                                 HorizontalItemSpacing="12"
                                 VerticalItemSpacing="12" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Poi">
                    <Border BackgroundColor="White"
                            Stroke="#DDE6E2"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 18">
                        <Border.Shadow>
                            <Shadow Brush="#12312B"
                                    Offset="0,8"
                                    Radius="14"
                                    Opacity="0.06" />
                        </Border.Shadow>

                        <Grid RowDefinitions="112,Auto">
                            <Grid>
                                <Image Source="{Binding ImageUrl}"
                                       Aspect="AspectFill"
                                       HeightRequest="112" />

                                <Button Text="🔊"
                                        WidthRequest="34"
                                        HeightRequest="34"
                                        CornerRadius="17"
                                        FontSize="13"
                                        BackgroundColor="White"
                                        TextColor="#1F6F64"
                                        HorizontalOptions="End"
                                        VerticalOptions="End"
                                        Margin="0,0,8,8"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PlayPoiAudioCommand}"
                                        CommandParameter="{Binding}" />
                            </Grid>

                            <VerticalStackLayout Grid.Row="1"
                                                 Padding="10,10,10,12"
                                                 Spacing="3">
                                <Label Text="{Binding Name}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#173330"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1" />

                                <Label Text="{Binding Address}"
                                       FontSize="11.5"
                                       TextColor="#617A74"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="2" />
                            </VerticalStackLayout>

                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPoiCardTapped" />
                            </Grid.GestureRecognizers>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Border x:Name="MiniPlayerContainer"
                Grid.Row="3"
                Margin="16,6,16,10"
                IsVisible="{Binding ShowMiniPlayer}"
                BackgroundColor="White"
                Stroke="#CFE0DA"
                StrokeThickness="1"
                Padding="14"
                StrokeShape="RoundRectangle 22">
            <Border.Shadow>
                <Shadow Brush="#12312B"
                        Offset="0,8"
                        Radius="16"
                        Opacity="0.08" />
            </Border.Shadow>
            <Grid ColumnDefinitions="Auto,*,Auto"
                  RowDefinitions="Auto,Auto,Auto"
                  ColumnSpacing="12"
                  RowSpacing="4">
                <Border Grid.RowSpan="3"
                        WidthRequest="58"
                        HeightRequest="58"
                        BackgroundColor="#EAF4F1"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 18">
                    <Grid>
                        <Image Source="{Binding CurrentNarrationImageUrl}"
                               Aspect="AspectFill" />
                        <Border BackgroundColor="#DDEFE9"
                                Opacity="0.35"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18" />
                        <Label Text="TTS"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               FontSize="12"
                               FontAttributes="Bold"
                               TextColor="#1F6F64" />
                    </Grid>
                </Border>

                <HorizontalStackLayout Grid.Column="1"
                                       Grid.ColumnSpan="2"
                                       Spacing="8">
                    <Border BackgroundColor="#EAF4F1"
                            Padding="8,4"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 10">
                        <Label Text="{Binding MiniPlayerStateTag}"
                               FontSize="10"
                               FontAttributes="Bold"
                               TextColor="#1F6F64" />
                    </Border>

                    <Label Text="{Binding MiniPlayerStatusText}"
                           FontSize="11"
                           FontAttributes="Bold"
                           TextColor="#48635F"
                           VerticalTextAlignment="Center" />
                </HorizontalStackLayout>

                <VerticalStackLayout Grid.Row="1"
                                     Grid.Column="1"
                                     Spacing="2">
                    <Label Text="{Binding CurrentNarrationTitle}"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="#173330"
                           LineBreakMode="TailTruncation"
                           MaxLines="1" />
                    <Label Text="{Binding CurrentNarrationSubtitle}"
                           FontSize="11"
                           TextColor="#617A74"
                           LineBreakMode="TailTruncation"
                           MaxLines="1" />
                </VerticalStackLayout>

                <Button x:Name="MiniPlayerStopButton"
                        Grid.Row="1"
                        Grid.Column="2"
                        Command="{Binding StopNarrationCommand}"
                        WidthRequest="64"
                        HeightRequest="34"
                        CornerRadius="12"
                        BackgroundColor="#173330"
                        TextColor="White"
                        FontSize="11"
                        FontAttributes="Bold"
                        IsEnabled="{Binding IsNarrationPlaying}" />

                <VerticalStackLayout Grid.Row="2"
                                     Grid.Column="1"
                                     Grid.ColumnSpan="2"
                                     Spacing="6">
                    <ProgressBar Progress="{Binding MiniPlayerProgress}"
                                 HeightRequest="4"
                                 BackgroundColor="#DCE6E2"
                                 ProgressColor="#1F6F64" />
                    <Label Text="{Binding MiniPlayerHintText}"
                           FontSize="10"
                           TextColor="#617A74" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <Border Grid.Row="4"
                Margin="12,0,12,12"
                BackgroundColor="White"
                Stroke="#D8E2DE"
                StrokeThickness="1"
                Padding="8"
                StrokeShape="RoundRectangle 22">
            <Grid ColumnDefinitions="*,*,*,*"
                  ColumnSpacing="6">
                <Border Grid.Column="0"
                        BackgroundColor="#EAF4F1"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 16"
                        Padding="0">
                    <Button x:Name="NavHomeButton"
                            Clicked="OnGoHomeClicked"
                            FontSize="11"
                            FontAttributes="Bold"
                            BackgroundColor="Transparent"
                            TextColor="#1F6F64"
                            Padding="4,8"
                            ImageSource="nav_home.svg"
                            ContentLayout="Top,4"
                            HorizontalOptions="Fill"
                            VerticalOptions="Fill" />
                </Border>

                <Button x:Name="NavMapButton"
                        Grid.Column="1"
                        Clicked="OnOpenFullMapClicked"
                        FontSize="11"
                        BackgroundColor="Transparent"
                        TextColor="#617A74"
                        Padding="4,8"
                        ImageSource="nav_map.svg"
                        ContentLayout="Top,4"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill" />

                <Button x:Name="NavHistoryButton"
                        Grid.Column="2"
                        Clicked="OnHistoryClicked"
                        FontSize="11"
                        BackgroundColor="Transparent"
                        TextColor="#617A74"
                        Padding="4,8"
                        ImageSource="nav_history.svg"
                        ContentLayout="Top,4"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill" />

                <Button x:Name="NavAccountButton"
                        Grid.Column="3"
                        Clicked="OnUserClicked"
                        FontSize="11"
                        BackgroundColor="Transparent"
                        TextColor="#617A74"
                        Padding="4,8"
                        ImageSource="nav_account.svg"
                        ContentLayout="Top,4"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill" />
            </Grid>
        </Border>
    </Grid>
</ContentPage>

