<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
        x:Class="VKFoodArea.Features.Home.FullMapPage"
        xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
        xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
        BackgroundColor="#F4F7F6"
        NavigationPage.HasNavigationBar="False"
        Shell.NavBarIsVisible="False">

        <Grid RowDefinitions="Auto,*,Auto,Auto"
              BackgroundColor="#F4F7F6">

                <Border Grid.Row="0"
                        Margin="16,14,16,10"
                        Padding="14"
                        BackgroundColor="White"
                        Stroke="#D9E3DF"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 24">
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="12">

                                <Button Text="←"
                                        Clicked="OnGoHomeClicked"
                                        WidthRequest="44"
                                        HeightRequest="44"
                                        CornerRadius="14"
                                        BackgroundColor="#EAF4F1"
                                        TextColor="#1F6F64"
                                        FontSize="18"
                                        FontAttributes="Bold"/>

                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="2"
                                                     VerticalOptions="Center">
                                        <Label x:Name="PageTitleLabel"
                                               Text="Bản đồ khám phá"
                                               FontSize="22"
                                               FontAttributes="Bold"
                                               TextColor="#173330"/>

                                        <Label Text="{Binding NearestPoiText}"
                                               FontSize="12"
                                               TextColor="#6A7F79"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="1"/>

                                        <HorizontalStackLayout Margin="0,6,0,0"
                                                               Spacing="8">
                                                <Button x:Name="DemoMenuButton"
                                                        Text="Demo"
                                                        Clicked="OnDemoMenuClicked"
                                                        HeightRequest="34"
                                                        Padding="14,0"
                                                        CornerRadius="12"
                                                        BackgroundColor="#EAF4F1"
                                                        TextColor="#1F6F64"
                                                        FontSize="11"
                                                        FontAttributes="Bold"/>

                                                <Button x:Name="RealGpsButton"
                                                        Text="GPS thật"
                                                        Clicked="OnRealGpsClicked"
                                                        IsVisible="False"
                                                        HeightRequest="34"
                                                        Padding="14,0"
                                                        CornerRadius="12"
                                                        BackgroundColor="#173330"
                                                        TextColor="White"
                                                        FontSize="11"
                                                        FontAttributes="Bold"/>
                                        </HorizontalStackLayout>

                                        <Label x:Name="DemoModeLabel"
                                               IsVisible="False"
                                               FontSize="11"
                                               TextColor="#8A5A00"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="1"/>
                                </VerticalStackLayout>

                                <Border Grid.Column="2"
                                        Padding="12,8"
                                        BackgroundColor="#EAF4F1"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 14"
                                        VerticalOptions="Center">
                                        <Label x:Name="MapBadgeLabel"
                                               Text="Bản đồ"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               TextColor="#1F6F64"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center"/>
                                </Border>
                        </Grid>
                </Border>

                <Grid Grid.Row="1"
                      Margin="16,0,16,10">
                        <Border BackgroundColor="White"
                                Stroke="#D9E3DF"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 26">
                                <Grid>
                                        <ContentView x:Name="MapHost"
                                                     HorizontalOptions="Fill"
                                                     VerticalOptions="Fill"/>

                                        <VerticalStackLayout Margin="0,0,12,12"
                                                             Spacing="10"
                                                             HorizontalOptions="End"
                                                             VerticalOptions="End">

                                                <Button Text="◎"
                                                        Clicked="OnMyLocationClicked"
                                                        WidthRequest="48"
                                                        HeightRequest="48"
                                                        CornerRadius="24"
                                                        BackgroundColor="White"
                                                        TextColor="#173330"
                                                        BorderColor="#D9E3DF"
                                                        BorderWidth="1"
                                                        FontSize="16"/>

                                                <Button Text="+"
                                                        Clicked="OnZoomInClicked"
                                                        WidthRequest="48"
                                                        HeightRequest="48"
                                                        CornerRadius="24"
                                                        BackgroundColor="White"
                                                        TextColor="#173330"
                                                        BorderColor="#D9E3DF"
                                                        BorderWidth="1"
                                                        FontSize="22"
                                                        FontAttributes="Bold"/>

                                                <Button Text="−"
                                                        Clicked="OnZoomOutClicked"
                                                        WidthRequest="48"
                                                        HeightRequest="48"
                                                        CornerRadius="24"
                                                        BackgroundColor="White"
                                                        TextColor="#173330"
                                                        BorderColor="#D9E3DF"
                                                        BorderWidth="1"
                                                        FontSize="22"
                                                        FontAttributes="Bold"/>
                                        </VerticalStackLayout>
                                </Grid>
                        </Border>
                </Grid>

                <Border Grid.Row="2"
                        Margin="16,0,16,10"
                        Padding="14,12"
                        BackgroundColor="White"
                        Stroke="#D9E3DF"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 20">
                        <VerticalStackLayout Spacing="2">
                                <Label Text="Trạng thái bản đồ"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="#6A7F79"/>
                                <Label x:Name="InfoLabel"
                                       FontSize="13"
                                       TextColor="#35534D"
                                       LineBreakMode="WordWrap"
                                       MaxLines="3"/>
                        </VerticalStackLayout>
                </Border>

                <Border Grid.Row="3"
                        Margin="12,0,12,12"
                        Padding="8"
                        BackgroundColor="White"
                        Stroke="#D9E3DF"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 24">
                        <Grid ColumnDefinitions="*,*,*,*"
                              ColumnSpacing="6">
                                <Button x:Name="NavHomeButton"
                                        Grid.Column="0"
                                        Text="Trang chủ"
                                        Clicked="OnGoHomeClicked"
                                        BackgroundColor="Transparent"
                                        TextColor="#617A74"
                                        FontSize="11"
                                        Padding="4,8"/>

                                <Button x:Name="NavMapButton"
                                        Grid.Column="1"
                                        Text="Bản đồ"
                                        Clicked="OnMapCurrentClicked"
                                        BackgroundColor="#EAF4F1"
                                        TextColor="#1F6F64"
                                        FontSize="11"
                                        FontAttributes="Bold"
                                        Padding="4,8"/>

                                <Button x:Name="NavHistoryButton"
                                        Grid.Column="2"
                                        Text="Lịch sử"
                                        Clicked="OnHistoryClicked"
                                        BackgroundColor="Transparent"
                                        TextColor="#617A74"
                                        FontSize="11"
                                        Padding="4,8"/>

                                <Button x:Name="NavAccountButton"
                                        Grid.Column="3"
                                        Text="Tài khoản"
                                        Clicked="OnUserClicked"
                                        BackgroundColor="Transparent"
                                        TextColor="#617A74"
                                        FontSize="11"
                                        Padding="4,8"/>
                        </Grid>
                </Border>
        </Grid>
</ContentPage>