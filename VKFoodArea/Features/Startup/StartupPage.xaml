<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="VKFoodArea.Features.Startup.StartupPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#0F1513">
    <Grid>
        <VerticalStackLayout
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Spacing="18">
            <Label
                Text="VKFoodArea"
                FontSize="28"
                FontAttributes="Bold"
                TextColor="White"
                HorizontalTextAlignment="Center" />
            <ActivityIndicator
                IsRunning="True"
                Color="#17C5A3"
                WidthRequest="42"
                HeightRequest="42" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>

