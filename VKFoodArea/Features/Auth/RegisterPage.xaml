<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="VKFoodArea.Features.Auth.RegisterPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#EEF4F1"
    NavigationPage.HasNavigationBar="False"
    Title="">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="1,1">
                <GradientStop Color="#DDF5ED" Offset="0.0" />
                <GradientStop Color="#F8F4EA" Offset="0.58" />
                <GradientStop Color="#F3FBF8" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <Border Margin="-80,-30,120,0"
                BackgroundColor="#58A8E7DA"
                HorizontalOptions="Start"
                VerticalOptions="Start"
                WidthRequest="210"
                HeightRequest="210"
                Rotation="-20"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 98" />

        <Border Margin="160,130,-70,0"
                BackgroundColor="#4BFFDDB6"
                HorizontalOptions="End"
                VerticalOptions="Start"
                WidthRequest="170"
                HeightRequest="170"
                Rotation="16"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 82" />

        <Border Margin="-10,260,170,-80"
                BackgroundColor="#2CFFFFFF"
                HorizontalOptions="Start"
                VerticalOptions="End"
                WidthRequest="170"
                HeightRequest="170"
                Rotation="26"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 52" />

        <Border Margin="150,360,-30,-60"
                BackgroundColor="#32BDE8D7"
                HorizontalOptions="End"
                VerticalOptions="End"
                WidthRequest="150"
                HeightRequest="150"
                Rotation="-18"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 46" />

        <ScrollView>
            <VerticalStackLayout Padding="20,44,20,28"
                                 Spacing="18">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="12">
                    <Button x:Name="BackButton"
                            Clicked="OnBackClicked"
                            WidthRequest="46"
                            HeightRequest="46"
                            CornerRadius="16"
                            BackgroundColor="#F4FBF8"
                            TextColor="#18443D"
                            FontAttributes="Bold"
                            Text="&lt;" />

                    <Border Grid.Column="1"
                            Padding="22"
                            StrokeThickness="0">
                        <Border.Background>
                            <LinearGradientBrush EndPoint="1,1">
                                <GradientStop Color="#143C36" Offset="0.0" />
                                <GradientStop Color="#2F8E80" Offset="0.62" />
                                <GradientStop Color="#6AD6C1" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="28" />
                        </Border.StrokeShape>

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="12">
                            <Border WidthRequest="52"
                                    HeightRequest="52"
                                    BackgroundColor="#24FFFFFF"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 18">
                                <Label Text="VK"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="White" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1"
                                                 VerticalOptions="Center"
                                                 Spacing="2">
                                <Label Text="VKFoodArea"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="White" />
                                <Label x:Name="RegisterHeroLabel"
                                       FontSize="12"
                                       TextColor="#DFFBF5" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </Grid>

                <Border BackgroundColor="White"
                        Stroke="#D7E4DF"
                        StrokeThickness="1"
                        Padding="20"
                        StrokeShape="RoundRectangle 28">
                    <Border.Shadow>
                        <Shadow Brush="#799E98"
                                Offset="0,12"
                                Radius="24"
                                Opacity="0.12" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="16">
                        <VerticalStackLayout Spacing="3">
                            <Label x:Name="RegisterTitleLabel"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="#163632" />
                            <Label x:Name="RegisterSubtitleLabel"
                                   FontSize="13"
                                   TextColor="#6D8681" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label x:Name="FullNameLabel"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#4F6B66" />
                            <Border BackgroundColor="#F7FBF9"
                                    Stroke="#D7E4DF"
                                    StrokeThickness="1"
                                    Padding="14,6"
                                    StrokeShape="RoundRectangle 18">
                                <Entry x:Name="FullNameEntry"
                                       ReturnType="Next"
                                       Completed="OnFullNameCompleted"
                                       TextColor="#163632"
                                       PlaceholderColor="#90AAA4" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label x:Name="EmailLabel"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#4F6B66" />
                            <Border BackgroundColor="#F7FBF9"
                                    Stroke="#D7E4DF"
                                    StrokeThickness="1"
                                    Padding="14,6"
                                    StrokeShape="RoundRectangle 18">
                                <Entry x:Name="EmailEntry"
                                       Keyboard="Email"
                                       ReturnType="Next"
                                       Completed="OnEmailCompleted"
                                       TextColor="#163632"
                                       PlaceholderColor="#90AAA4"
                                       ClearButtonVisibility="WhileEditing" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label x:Name="PasswordLabel"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#4F6B66" />
                            <Border BackgroundColor="#F7FBF9"
                                    Stroke="#D7E4DF"
                                    StrokeThickness="1"
                                    Padding="14,6"
                                    StrokeShape="RoundRectangle 18">
                                <Entry x:Name="PasswordEntry"
                                       IsPassword="True"
                                       ReturnType="Next"
                                       Completed="OnPasswordCompleted"
                                       TextColor="#163632"
                                       PlaceholderColor="#90AAA4" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label x:Name="ConfirmPasswordLabel"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#4F6B66" />
                            <Border BackgroundColor="#F7FBF9"
                                    Stroke="#D7E4DF"
                                    StrokeThickness="1"
                                    Padding="14,6"
                                    StrokeShape="RoundRectangle 18">
                                <Entry x:Name="ConfirmPasswordEntry"
                                       IsPassword="True"
                                       ReturnType="Go"
                                       Completed="OnConfirmPasswordCompleted"
                                       TextColor="#163632"
                                       PlaceholderColor="#90AAA4" />
                            </Border>
                        </VerticalStackLayout>

                        <Button x:Name="RegisterButton"
                                Clicked="OnRegisterClicked"
                                BackgroundColor="#129488"
                                TextColor="White"
                                CornerRadius="18"
                                HeightRequest="56"
                                FontAttributes="Bold"
                                FontSize="15" />

                        <Label x:Name="MessageLabel"
                               TextColor="#C23546"
                               FontSize="13"
                               LineBreakMode="WordWrap" />

                        <Button x:Name="BackToLoginButton"
                                Clicked="OnBackClicked"
                                BackgroundColor="#EEF5F2"
                                TextColor="#35534D"
                                CornerRadius="18"
                                HeightRequest="50"
                                FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
