<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="VKFoodArea.Features.User.UserPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#EEF4F1"
    NavigationPage.HasNavigationBar="False"
    Shell.NavBarIsVisible="False"
    Title="">

    <Grid RowDefinitions="Auto,*,Auto"
          BackgroundColor="#EEF4F1">
        <Border Grid.Row="0"
                Margin="14,10,14,10"
                Padding="18,18"
                StrokeThickness="0">
            <Border.Background>
                <LinearGradientBrush EndPoint="1,1">
                    <GradientStop Color="#0E9A91" Offset="0.0" />
                    <GradientStop Color="#38C3B4" Offset="0.58" />
                    <GradientStop Color="#7BE8D1" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="30" />
            </Border.StrokeShape>
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                <Border WidthRequest="66" HeightRequest="66" BackgroundColor="#DFFFF8" StrokeThickness="0" StrokeShape="RoundRectangle 33">
                    <Label x:Name="AvatarLabel" HorizontalOptions="Center" VerticalOptions="Center" FontSize="22" FontAttributes="Bold" TextColor="#129488" />
                </Border>
                <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                    <Label x:Name="HeaderTagLabel" FontSize="14" FontAttributes="Bold" TextColor="#E6FFFB" />
                    <Label x:Name="FullNameLabel" FontSize="24" FontAttributes="Bold" FontFamily="OpenSansSemibold" TextColor="White" />
                    <Label x:Name="UsernameLabel" FontSize="13" TextColor="#E6FFFB" />
                </VerticalStackLayout>
                <Button Grid.Column="2" Text="⚙" Clicked="OnOpenProfileClicked" WidthRequest="40" HeightRequest="40" CornerRadius="20" BackgroundColor="#33FFFFFF" TextColor="White" />
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,0,16,16" Spacing="14">
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Border BackgroundColor="White" Stroke="#D7E4DF" StrokeThickness="1" Padding="14" StrokeShape="RoundRectangle 20">
                        <VerticalStackLayout Spacing="6">
                            <Label x:Name="CurrentLanguageTitleLabel" FontSize="13" TextColor="#6A8781" />
                            <Label x:Name="CurrentLanguageValueLabel" FontSize="18" FontAttributes="Bold" TextColor="#163632" />
                            <Label x:Name="CurrentLanguageHintLabel" FontSize="12" TextColor="#129488" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" BackgroundColor="#E6FAF5" StrokeThickness="0" Padding="14" StrokeShape="RoundRectangle 20">
                        <VerticalStackLayout Spacing="6">
                            <Label x:Name="UserTypeTitleLabel" FontSize="13" TextColor="#6A8781" />
                            <Label x:Name="UserTypeValueLabel" FontSize="18" FontAttributes="Bold" TextColor="#163632" />
                            <Label x:Name="NarrationModeValueLabel" FontSize="12" TextColor="#129488" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Border BackgroundColor="White" Stroke="#D7E4DF" StrokeThickness="1" Padding="16" StrokeShape="RoundRectangle 22">
                    <VerticalStackLayout Spacing="12">
                        <Label x:Name="AccountInfoTitleLabel" FontSize="17" FontAttributes="Bold" FontFamily="OpenSansSemibold" TextColor="#163632" />
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="12">
                            <Label x:Name="UsernameTitleLabel" FontSize="14" TextColor="#6A8781" />
                            <Label Grid.Column="1" x:Name="UsernameValueLabel" FontSize="14" FontAttributes="Bold" TextColor="#163632" />
                            <Label x:Name="RoleTitleLabel" Grid.Row="1" FontSize="14" TextColor="#6A8781" />
                            <Label Grid.Row="1" Grid.Column="1" x:Name="RoleValueLabel" FontSize="14" FontAttributes="Bold" TextColor="#163632" />
                            <Label x:Name="StatusTitleLabel" Grid.Row="2" FontSize="14" TextColor="#6A8781" />
                            <Label Grid.Row="2" Grid.Column="1" x:Name="StatusValueLabel" FontSize="14" FontAttributes="Bold" TextColor="#163632" />
                        </Grid>
                        <HorizontalStackLayout Spacing="8">
                            <Border BackgroundColor="#DFF7F2" StrokeThickness="0" Padding="10,6" StrokeShape="RoundRectangle 14"><Label x:Name="RoleBadgeLabel" FontSize="12" FontAttributes="Bold" TextColor="#129488" /></Border>
                            <Border BackgroundColor="#101415" StrokeThickness="0" Padding="10,6" StrokeShape="RoundRectangle 14"><Label x:Name="StatusBadgeLabel" FontSize="12" FontAttributes="Bold" TextColor="White" /></Border>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="White" Stroke="#D7E4DF" StrokeThickness="1" Padding="16" StrokeShape="RoundRectangle 22">
                    <VerticalStackLayout Spacing="12">
                        <Label x:Name="QuickActionsTitleLabel" FontSize="17" FontAttributes="Bold" FontFamily="OpenSansSemibold" TextColor="#163632" />
                        <Button x:Name="OpenSettingsButton" Clicked="OnOpenSettingsClicked" BackgroundColor="#129488" TextColor="White" CornerRadius="16" HeightRequest="48" FontAttributes="Bold" />
                        <Button x:Name="LogoutButton" Clicked="OnLogoutClickedEscaped" BackgroundColor="#101415" TextColor="White" CornerRadius="16" HeightRequest="48" FontAttributes="Bold" />
                        <Label x:Name="FooterNoteLabel" FontSize="12" TextColor="#6A8781" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="2" Margin="12,0,12,12" BackgroundColor="White" StrokeThickness="0" Padding="8" StrokeShape="RoundRectangle 24">
            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="6">
                <Button x:Name="NavHomeButton"
                        Grid.Column="0"
                        Clicked="OnGoHomeClicked"
                        BackgroundColor="Transparent"
                        TextColor="#708682"
                        FontSize="11"
                        Padding="4,8"
                        ImageSource="nav_home.svg"
                        ContentLayout="Top,4" />
                <Button x:Name="NavMapButton"
                        Grid.Column="1"
                        Clicked="OnOpenFullMapClicked"
                        BackgroundColor="Transparent"
                        TextColor="#708682"
                        FontSize="11"
                        Padding="4,8"
                        ImageSource="nav_map.svg"
                        ContentLayout="Top,4" />
                <Button x:Name="NavHistoryButton"
                        Grid.Column="2"
                        Clicked="OnHistoryClicked"
                        BackgroundColor="Transparent"
                        TextColor="#708682"
                        FontSize="11"
                        Padding="4,8"
                        ImageSource="nav_history.svg"
                        ContentLayout="Top,4" />
                <Border Grid.Column="3" BackgroundColor="#DDF7F1" StrokeThickness="0" StrokeShape="RoundRectangle 18">
                    <Button x:Name="NavAccountButton"
                            Clicked="OnUserClicked"
                            BackgroundColor="Transparent"
                            TextColor="#159487"
                            FontSize="11"
                            FontAttributes="Bold"
                            Padding="4,8"
                            ImageSource="nav_account.svg"
                            ContentLayout="Top,4" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</ContentPage>

