<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Brand -->
    <Color x:Key="ColorPrimary">#11998E</Color>
    <Color x:Key="ColorPrimaryDark">#0A6E68</Color>
    <Color x:Key="ColorPrimaryLight">#DDF7F1</Color>

    <!-- Background / Surface -->
    <Color x:Key="ColorBackground">#EEF4F1</Color>
    <Color x:Key="ColorSurface">#FFFFFF</Color>
    <Color x:Key="ColorSurfaceSoft">#F7FBF9</Color>
    <Color x:Key="ColorBorder">#D7E4DF</Color>

    <!-- Text -->
    <Color x:Key="ColorTextPrimary">#163632</Color>
    <Color x:Key="ColorTextSecondary">#6C8781</Color>
    <Color x:Key="ColorTextLight">#FFFFFF</Color>

    <!-- Accent -->
    <Color x:Key="ColorWarning">#E7BC55</Color>
    <Color x:Key="ColorDanger">#D65762</Color>
    <Color x:Key="ColorInfo">#54A7D8</Color>

</ResourceDictionary>
