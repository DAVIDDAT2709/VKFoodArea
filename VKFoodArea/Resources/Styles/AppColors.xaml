<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Brand -->
    <Color x:Key="ColorPrimary">#16A34A</Color>
    <Color x:Key="ColorPrimaryDark">#15803D</Color>
    <Color x:Key="ColorPrimaryLight">#DCFCE7</Color>

    <!-- Background / Surface -->
    <Color x:Key="ColorBackground">#F5F7FA</Color>
    <Color x:Key="ColorSurface">#FFFFFF</Color>
    <Color x:Key="ColorSurfaceSoft">#F9FAFB</Color>
    <Color x:Key="ColorBorder">#E5E7EB</Color>

    <!-- Text -->
    <Color x:Key="ColorTextPrimary">#111827</Color>
    <Color x:Key="ColorTextSecondary">#6B7280</Color>
    <Color x:Key="ColorTextLight">#FFFFFF</Color>

    <!-- Accent -->
    <Color x:Key="ColorWarning">#F59E0B</Color>
    <Color x:Key="ColorDanger">#EF4444</Color>
    <Color x:Key="ColorInfo">#0EA5E9</Color>

</ResourceDictionary>