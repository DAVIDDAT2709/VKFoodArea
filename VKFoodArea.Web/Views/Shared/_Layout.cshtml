@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var pageTitle = (string?)ViewData["Title"] ?? "VK Food Area";
    var showDashboardTopbar = string.Equals(currentController, "Home", StringComparison.OrdinalIgnoreCase);

    string NavClass(string controller) =>
        string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)
            ? "app-nav__link active"
            : "app-nav__link";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - VK Food Area</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/VKFoodArea.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <a class="skip-link" href="#main-content">Đến nội dung chính</a>

    <div class="app-shell">
        <aside class="app-sidebar">
            <a class="brand-mark" asp-controller="Home" asp-action="Index">
                <strong class="brand-mark__title">VK Food Area</strong>
            </a>

            <nav class="app-nav" aria-label="Menu quản trị">
                <a class="@NavClass("Home")" asp-controller="Home" asp-action="Index">
                    <span class="app-nav__icon">DB</span>
                    <span class="app-nav__content">
                        <span class="app-nav__title">Tổng quan</span>
                    </span>
                </a>

                <a class="@NavClass("Pois")" asp-controller="Pois" asp-action="Index">
                    <span class="app-nav__icon">POI</span>
                    <span class="app-nav__content">
                        <span class="app-nav__title">Điểm POI</span>
                    </span>
                </a>

                <a class="@NavClass("Tours")" asp-controller="Tours" asp-action="Index">
                    <span class="app-nav__icon">TR</span>
                    <span class="app-nav__content">
                        <span class="app-nav__title">Tour</span>
                    </span>
                </a>

                <a class="@NavClass("Map")" asp-controller="Map" asp-action="Index">
                    <span class="app-nav__icon">MP</span>
                    <span class="app-nav__content">
                        <span class="app-nav__title">Bản đồ Analytics</span>
                    </span>
                </a>

                <a class="@NavClass("QrCodeItems")" asp-controller="QrCodeItems" asp-action="Index">
                    <span class="app-nav__icon">QR</span>
                    <span class="app-nav__content">
                        <span class="app-nav__title">Mã QR</span>
                    </span>
                </a>

                <a class="@NavClass("AdminUsers")" asp-controller="AdminUsers" asp-action="Index">
                    <span class="app-nav__icon">AD</span>
                    <span class="app-nav__content">
                        <span class="app-nav__title">Quản trị viên</span>
                    </span>
                </a>

                <a class="@NavClass("NarrationHistories")" asp-controller="NarrationHistories" asp-action="Index">
                    <span class="app-nav__icon">LG</span>
                    <span class="app-nav__content">
                        <span class="app-nav__title">Lịch sử nghe</span>
                    </span>
                </a>
            </nav>
        </aside>

        <div class="app-main">
            @if (showDashboardTopbar)
            {
                <header class="topbar">
                    <div class="topbar__content">
                        <h1 class="topbar__title">@pageTitle</h1>
                    </div>

                    <div class="topbar__actions">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <form asp-controller="Account" asp-action="Logout" method="post" class="logout-form">
                                <span class="soft-pill soft-pill--neutral">@User.Identity.Name</span>
                                <button type="submit" class="btn btn-outline-secondary">Đăng xuất</button>
                            </form>
                        }
                        <a asp-controller="Pois" asp-action="Create" class="btn btn-primary">Thêm POI</a>
                        <a asp-controller="Tours" asp-action="Create" class="btn btn-outline-secondary">Thêm Tour</a>
                        <a asp-controller="QrCodeItems" asp-action="Create" class="btn btn-outline-secondary">Thêm QR</a>
                    </div>
                </header>
            }

            <div class="page-wrap">
                @if (TempData["SuccessMessage"] is string message)
                {
                    <div class="alert alert-success alert-dismissible fade show page-section" role="alert">
                        @message
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
                    </div>
                }

                @if (TempData["ErrorMessage"] is string errorMessage)
                {
                    <div class="alert alert-danger alert-dismissible fade show page-section" role="alert">
                        @errorMessage
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
                    </div>
                }

                <main id="main-content" class="page-content" role="main">
                    @RenderBody()
                </main>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
