@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;

    string NavClass(string controller) =>
        string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)
            ? "app-nav__link active"
            : "app-nav__link";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Narration CMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/VKFoodArea.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <a class="skip-link" href="#main-content">Chuyển đến nội dung chính</a>

    <div class="app-shell">
        <aside class="app-sidebar">
            <a class="brand-mark" asp-controller="Home" asp-action="Index">
                <strong class="brand-mark__title">VK Food Area</strong>
                <strong class="brand-mark__meta">Narration CMS</strong>
            </a>

            <nav class="app-nav" aria-label="Điều hướng chính">
                <a class="@NavClass("Home")" asp-controller="Home" asp-action="Index">Tổng quan</a>
                <a class="@NavClass("Pois")" asp-controller="Pois" asp-action="Index">Điểm POI</a>
                <a class="@NavClass("Tours")" asp-controller="Tours" asp-action="Index">Tour</a>
                <a class="@NavClass("Map")" asp-controller="Map" asp-action="Index">Map POI</a>
                <a class="@NavClass("QrCodeItems")" asp-controller="QrCodeItems" asp-action="Index">QR code</a>
                <a class="@NavClass("AdminUsers")" asp-controller="AdminUsers" asp-action="Index">Admin users</a>
                <a class="@NavClass("NarrationHistories")" asp-controller="NarrationHistories" asp-action="Index">Lịch sử nghe</a>
            </nav>
        </aside>

        <div class="app-main">
            <header class="topbar">
                <h1 class="topbar__title">@((string?)ViewData["Title"] ?? "Narration CMS")</h1>

                <div class="topbar__actions">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <form asp-controller="Account" asp-action="Logout" method="post" class="logout-form">
                            <span class="soft-pill">@User.Identity.Name</span>
                            <button type="submit" class="btn btn-outline-secondary">Dang xuat</button>
                        </form>
                    }
                    <a asp-controller="Pois" asp-action="Create" class="btn btn-primary">Thêm POI</a>
                    <a asp-controller="Tours" asp-action="Create" class="btn btn-outline-secondary">Thêm tour</a>
                    <a asp-controller="QrCodeItems" asp-action="Create" class="btn btn-outline-secondary">Thêm QR</a>
                </div>
            </header>

            <div class="page-wrap">
                @if (TempData["SuccessMessage"] is string message)
                {
                    <div class="alert alert-success alert-dismissible fade show page-section" role="alert">
                        @message
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
                    </div>
                }

                @if (TempData["ErrorMessage"] is string errorMessage)
                {
                    <div class="alert alert-danger alert-dismissible fade show page-section" role="alert">
                        @errorMessage
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Dong"></button>
                    </div>
                }

                <main id="main-content" class="page-content" role="main">
                    @RenderBody()
                </main>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
