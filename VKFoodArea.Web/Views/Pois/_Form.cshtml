@model VKFoodArea.Web.ViewModels.PoiFormViewModel

<div asp-validation-summary="ModelOnly" class="validation-summary"></div>
<input asp-for="ImageUrl" type="hidden" />

<div class="editor-layout">
    <section class="card-surface">
        <div class="section-heading">
            <h2>Thông tin địa điểm</h2>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" placeholder="Ví dụ: Ốc Vũ" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Address" class="form-label"></label>
                <input asp-for="Address" class="form-control" placeholder="Địa chỉ hiển thị trong app" />
                <span asp-validation-for="Address" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="PhoneNumber" class="form-label"></label>
                <input asp-for="PhoneNumber" class="form-control" placeholder="Số điện thoại" />
                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="ImageFile" class="form-label"></label>
                <input asp-for="ImageFile" class="form-control" type="file" accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" />
                <span asp-validation-for="ImageFile" class="text-danger"></span>
                <div class="form-text">Ảnh sẽ được tự động copy vào `VKFoodArea/Resources/Images` và đồng thời lưu lên web để app hiển thị ngay.</div>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
            {
                <div class="col-12">
                    <div class="border rounded-3 p-3 bg-light">
                        <div class="fw-semibold mb-2">Ảnh hiện tại</div>
                        @if (CanPreview(Model.ImageUrl))
                        {
                            <img src="@ToPreviewUrl(Model.ImageUrl)" alt="Ảnh POI" style="max-width: 220px; max-height: 160px; border-radius: 12px; object-fit: cover;" />
                        }
                        <div class="small text-muted mt-2">@Model.ImageUrl</div>
                    </div>
                </div>
            }
        </div>
    </section>

    <section class="card-surface">
        <div class="section-heading">
            <h2>GPS và QR</h2>
        </div>

        <div class="row g-3">
            <div class="col-md-3">
                <label asp-for="Latitude" class="form-label"></label>
                <input asp-for="Latitude" class="form-control" step="any" placeholder="10.760000" />
                <span asp-validation-for="Latitude" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Longitude" class="form-label"></label>
                <input asp-for="Longitude" class="form-control" step="any" placeholder="106.700000" />
                <span asp-validation-for="Longitude" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="RadiusMeters" class="form-label"></label>
                <input asp-for="RadiusMeters" class="form-control" step="any" placeholder="30" />
                <span asp-validation-for="RadiusMeters" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Priority" class="form-label"></label>
                <input asp-for="Priority" class="form-control" min="1" max="100" placeholder="1" />
                <span asp-validation-for="Priority" class="text-danger"></span>
            </div>
            <div class="col-md-8">
                <label asp-for="QrCode" class="form-label"></label>
                <input asp-for="QrCode" class="form-control" placeholder="Ví dụ: poi:oc-vu" />
                <span asp-validation-for="QrCode" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <div class="form-check form-switch field-switch">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label"></label>
                </div>
            </div>
        </div>
    </section>

    <section class="card-surface">
        <div class="section-heading">
            <h2>TTS</h2>
        </div>

        <div class="row g-3">
            <div class="col-12">
                <label asp-for="TtsScriptVi" class="form-label"></label>
                <textarea asp-for="TtsScriptVi" class="form-control" rows="7" placeholder="Nhập TTS tiếng Việt"></textarea>
                <span asp-validation-for="TtsScriptVi" class="text-danger"></span>
            </div>

            <div class="col-12">
                <div class="readonly-grid">
                    <div>
                        <label asp-for="TtsScriptEn" class="form-label"></label>
                        <textarea asp-for="TtsScriptEn" class="form-control" rows="5" placeholder="Tự sinh sau khi SAVE" readonly></textarea>
                        <span asp-validation-for="TtsScriptEn" class="text-danger"></span>
                    </div>
                    <div>
                        <label asp-for="TtsScriptZh" class="form-label"></label>
                        <textarea asp-for="TtsScriptZh" class="form-control" rows="5" placeholder="Tự sinh sau khi SAVE" readonly></textarea>
                        <span asp-validation-for="TtsScriptZh" class="text-danger"></span>
                    </div>
                    <div>
                        <label asp-for="TtsScriptJa" class="form-label"></label>
                        <textarea asp-for="TtsScriptJa" class="form-control" rows="5" placeholder="Tự sinh sau khi SAVE" readonly></textarea>
                        <span asp-validation-for="TtsScriptJa" class="text-danger"></span>
                    </div>
                    <div>
                        <label asp-for="TtsScriptDe" class="form-label"></label>
                        <textarea asp-for="TtsScriptDe" class="form-control" rows="5" placeholder="Tự sinh sau khi SAVE" readonly></textarea>
                        <span asp-validation-for="TtsScriptDe" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

@functions {
    private static bool CanPreview(string imageUrl)
        => imageUrl.StartsWith("/", StringComparison.Ordinal) ||
           imageUrl.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
           imageUrl.StartsWith("https://", StringComparison.OrdinalIgnoreCase);

    private static string ToPreviewUrl(string imageUrl)
        => imageUrl.StartsWith("/", StringComparison.Ordinal)
            ? imageUrl
            : imageUrl;
}
