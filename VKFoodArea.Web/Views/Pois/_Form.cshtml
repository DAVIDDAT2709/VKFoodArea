@model VKFoodArea.Web.ViewModels.PoiFormViewModel

<div asp-validation-summary="ModelOnly" class="validation-summary"></div>
<input asp-for="ImageUrl" type="hidden" />
<input asp-for="AudioFileVi" type="hidden" />
<input asp-for="AudioFileEn" type="hidden" />
<input asp-for="AudioFileJa" type="hidden" />
<input asp-for="QrCode" type="hidden" />
<input asp-for="ApprovalStatus" type="hidden" />
@if (!Model.CanEditActiveState)
{
    <input asp-for="IsActive" type="hidden" />
}

<div class="editor-layout">
    <section class="card-surface">
        <div class="section-heading">
            <h2>Thông tin địa điểm</h2>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" placeholder="Ví dụ: Ốc Sáu Nở" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Address" class="form-label"></label>
                <input asp-for="Address" class="form-control" placeholder="Địa chỉ hiển thị trong app" />
                <span asp-validation-for="Address" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="PhoneNumber" class="form-label"></label>
                <input asp-for="PhoneNumber" class="form-control" placeholder="Số điện thoại" />
                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="ImageFile" class="form-label"></label>
                <input asp-for="ImageFile" class="form-control" type="file" accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" />
                <span asp-validation-for="ImageFile" class="text-danger"></span>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
            {
                <div class="col-12">
                    <div class="border rounded-3 p-3 bg-light">
                        <div class="fw-semibold mb-2">Ảnh hiện tại</div>
                        @if (CanPreview(Model.ImageUrl))
                        {
                            <img src="@ToPreviewUrl(Model.ImageUrl)" alt="Ảnh POI" style="max-width: 220px; max-height: 160px; border-radius: 12px; object-fit: cover;" />
                        }
                        <div class="small text-muted mt-2">@Model.ImageUrl</div>
                    </div>
                </div>
            }
        </div>
    </section>

    <section class="card-surface">
        <div class="section-heading">
            <h2>Vị trí</h2>
        </div>

        <div class="row g-3">
            <div class="col-md-3">
                <label asp-for="Latitude" class="form-label"></label>
                <input asp-for="Latitude" type="number" inputmode="decimal" class="form-control" step="0.000001" asp-format="{0:0.######}" placeholder="10.760000" />
                <span asp-validation-for="Latitude" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Longitude" class="form-label"></label>
                <input asp-for="Longitude" type="number" inputmode="decimal" class="form-control" step="0.000001" asp-format="{0:0.######}" placeholder="106.700000" />
                <span asp-validation-for="Longitude" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="RadiusMeters" class="form-label"></label>
                <input asp-for="RadiusMeters" class="form-control" step="any" placeholder="30" />
                <span asp-validation-for="RadiusMeters" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Priority" class="form-label"></label>
                <input asp-for="Priority" class="form-control" min="1" max="100" placeholder="1" />
                <span asp-validation-for="Priority" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                @if (Model.CanEditActiveState)
                {
                    <div class="form-check form-switch field-switch">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label"></label>
                    </div>
                }
                else
                {
                    <div class="field-switch">
                        <span class="status-pill status-pill--info">@VKFoodArea.Web.Models.PoiApprovalStatus.DisplayName(Model.ApprovalStatus)</span>
                    </div>
                }
            </div>
            @if (Model.CanAssignOwner)
            {
                <div class="col-md-8">
                    <label asp-for="OwnerAdminUserId" class="form-label"></label>
                    <select asp-for="OwnerAdminUserId" asp-items="Model.OwnerOptions" class="form-select"></select>
                    <span asp-validation-for="OwnerAdminUserId" class="text-danger"></span>
                </div>
            }
        </div>
    </section>

    <section class="card-surface">
        <div class="section-heading">
            <h2>Nội dung TTS</h2>
        </div>

        <div class="row g-3">
            <div class="col-12">
                <label asp-for="TtsScriptVi" class="form-label"></label>
                <textarea asp-for="TtsScriptVi" class="form-control" rows="7" placeholder="Nhập TTS tiếng Việt"></textarea>
                <span asp-validation-for="TtsScriptVi" class="text-danger"></span>
            </div>

            <div class="col-12">
                <div class="readonly-grid">
                    <div>
                        <label asp-for="TtsScriptEn" class="form-label"></label>
                        <textarea asp-for="TtsScriptEn" class="form-control" rows="5" placeholder="Tự sinh sau khi lưu" readonly></textarea>
                        <span asp-validation-for="TtsScriptEn" class="text-danger"></span>
                    </div>
                    <div>
                        <label asp-for="TtsScriptZh" class="form-label"></label>
                        <textarea asp-for="TtsScriptZh" class="form-control" rows="5" placeholder="Tự sinh sau khi lưu" readonly></textarea>
                        <span asp-validation-for="TtsScriptZh" class="text-danger"></span>
                    </div>
                    <div>
                        <label asp-for="TtsScriptJa" class="form-label"></label>
                        <textarea asp-for="TtsScriptJa" class="form-control" rows="5" placeholder="Tự sinh sau khi lưu" readonly></textarea>
                        <span asp-validation-for="TtsScriptJa" class="text-danger"></span>
                    </div>
                    <div>
                        <label asp-for="TtsScriptDe" class="form-label"></label>
                        <textarea asp-for="TtsScriptDe" class="form-control" rows="5" placeholder="Tự sinh sau khi lưu" readonly></textarea>
                        <span asp-validation-for="TtsScriptDe" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="card-surface">
        <div class="section-heading">
            <h2>Tệp âm thanh</h2>
        </div>

        <div class="row g-3">
            <div class="col-md-4">
                <label asp-for="AudioFileViUpload" class="form-label"></label>
                <input asp-for="AudioFileViUpload" class="form-control" type="file" accept=".mp3,.m4a,.aac,.wav,.ogg,audio/*" />
                <span asp-validation-for="AudioFileViUpload" class="text-danger"></span>
                @RenderAudioCurrent(Model.AudioFileVi)
            </div>
            <div class="col-md-4">
                <label asp-for="AudioFileEnUpload" class="form-label"></label>
                <input asp-for="AudioFileEnUpload" class="form-control" type="file" accept=".mp3,.m4a,.aac,.wav,.ogg,audio/*" />
                <span asp-validation-for="AudioFileEnUpload" class="text-danger"></span>
                @RenderAudioCurrent(Model.AudioFileEn)
            </div>
            <div class="col-md-4">
                <label asp-for="AudioFileJaUpload" class="form-label"></label>
                <input asp-for="AudioFileJaUpload" class="form-control" type="file" accept=".mp3,.m4a,.aac,.wav,.ogg,audio/*" />
                <span asp-validation-for="AudioFileJaUpload" class="text-danger"></span>
                @RenderAudioCurrent(Model.AudioFileJa)
            </div>
        </div>
    </section>
</div>

@functions {
    private static bool CanPreview(string imageUrl)
        => imageUrl.StartsWith("/", StringComparison.Ordinal) ||
           imageUrl.StartsWith("uploads/", StringComparison.OrdinalIgnoreCase) ||
           imageUrl.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
           imageUrl.StartsWith("https://", StringComparison.OrdinalIgnoreCase);

    private static string ToPreviewUrl(string imageUrl)
        => imageUrl.StartsWith("/", StringComparison.Ordinal)
            ? imageUrl
            : imageUrl.StartsWith("uploads/", StringComparison.OrdinalIgnoreCase)
                ? $"/{imageUrl.TrimStart('/')}"
                : $"/uploads/poi-images/{System.IO.Path.GetFileName(imageUrl)}";

    private static Microsoft.AspNetCore.Html.IHtmlContent RenderAudioCurrent(string? audioUrl)
    {
        if (string.IsNullOrWhiteSpace(audioUrl))
            return new Microsoft.AspNetCore.Html.HtmlString(string.Empty);

        var encoded = System.Net.WebUtility.HtmlEncode(audioUrl);
        var source = audioUrl.StartsWith("/", StringComparison.Ordinal)
            ? encoded
            : encoded;

        return new Microsoft.AspNetCore.Html.HtmlString(
            $"""
            <div class="audio-current">
                <audio controls preload="none" src="{source}"></audio>
            </div>
            """);
    }
}
