@model VKFoodArea.Web.ViewModels.PoiIndexViewModel
@{
    ViewData["Title"] = "Điểm POI";
    var pois = Model.Items;
    var activeCount = Model.ActiveCount;
    var multilingualCount = pois.Count(x => GetLanguageCodes(x).Count >= 2);
    var audioReadyCount = pois.Count(x =>
        !string.IsNullOrWhiteSpace(x.AudioFileVi) ||
        !string.IsNullOrWhiteSpace(x.AudioFileEn) ||
        !string.IsNullOrWhiteSpace(x.AudioFileJa));
}

<section class="page-header page-section">
    <div>
        <h2>Điểm POI</h2>
    </div>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary">Thêm địa điểm</a>
    </div>
</section>

<section class="metrics-grid page-section">
    <article class="metric-card metric-card--blue">
        <span class="metric-card__label">Tổng POI</span>
        <strong class="metric-card__value">@Model.TotalCount</strong>
    </article>
    <article class="metric-card metric-card--green">
        <span class="metric-card__label">Đang hoạt động</span>
        <strong class="metric-card__value">@activeCount</strong>
    </article>
    <article class="metric-card metric-card--orange">
        <span class="metric-card__label">Có audio</span>
        <strong class="metric-card__value">@audioReadyCount</strong>
    </article>
    <article class="metric-card metric-card--red">
        <span class="metric-card__label">Đa ngôn ngữ</span>
        <strong class="metric-card__value">@multilingualCount</strong>
    </article>
    <article class="metric-card metric-card--orange">
        <span class="metric-card__label">Chờ duyệt</span>
        <strong class="metric-card__value">@Model.PendingCount</strong>
    </article>
</section>

<section class="card-surface page-section">
    <div class="section-heading">
        <h2>Tìm kiếm POI</h2>
        @if (Model.IsAdmin && Model.PendingCount > 0)
        {
            <span class="soft-pill">@Model.PendingCount điểm đang chờ admin duyệt</span>
        }
    </div>

    <form method="get" class="search-grid">
        <div class="search-grid__wide">
            <label class="form-label" for="query">Tên, địa chỉ, điện thoại, mã QR</label>
            <input id="query" name="query" class="form-control" value="@Model.Query" placeholder="Ví dụ: Ốc Oanh, Vĩnh Khánh, poi:oc-oanh..." />
        </div>
        <div>
            <label class="form-label" for="approvalStatus">Trạng thái duyệt</label>
            <select id="approvalStatus" name="approvalStatus" class="form-select">
                <option value="">Tất cả</option>
                <option value="@VKFoodArea.Web.Models.PoiApprovalStatus.Pending" selected="@(Model.ApprovalStatus == VKFoodArea.Web.Models.PoiApprovalStatus.Pending)">Chờ duyệt</option>
                <option value="@VKFoodArea.Web.Models.PoiApprovalStatus.Approved" selected="@(Model.ApprovalStatus == VKFoodArea.Web.Models.PoiApprovalStatus.Approved)">Đã duyệt</option>
                <option value="@VKFoodArea.Web.Models.PoiApprovalStatus.Rejected" selected="@(Model.ApprovalStatus == VKFoodArea.Web.Models.PoiApprovalStatus.Rejected)">Từ chối</option>
            </select>
        </div>
        <div class="search-actions">
            <button type="submit" class="btn btn-primary">Tìm kiếm</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Đặt lại</a>
        </div>
    </form>
</section>

<section class="card-surface page-section">
    <div class="section-heading">
        <h2>Danh sách POI</h2>
        <span class="soft-pill soft-pill--neutral">@pois.Count kết quả</span>
    </div>

    @if (!pois.Any())
    {
        <div class="empty-state">
            <p>Chưa có dữ liệu POI.</p>
        </div>
    }
    else
    {
        <div class="inventory-grid">
            @foreach (var poi in pois)
            {
                var languages = GetLanguageCodes(poi);
                <article class="inventory-card">
                    <div class="inventory-card__media">
                        @if (!string.IsNullOrWhiteSpace(poi.ImageUrl))
                        {
                            <img src="@ResolveImageUrl(poi.ImageUrl)" alt="@poi.Name" />
                        }
                        else
                        {
                            <div class="inventory-card__placeholder">POI</div>
                        }
                    </div>

                    <div class="inventory-card__body">
                        <div class="inventory-card__header">
                            <div>
                                <div class="inventory-card__title">@poi.Name</div>
                                <div class="inventory-card__meta">@poi.Address</div>
                                @if (!string.IsNullOrWhiteSpace(poi.PhoneNumber))
                                {
                                    <div class="inventory-card__meta">@poi.PhoneNumber</div>
                                }
                            </div>
                            <div class="pill-cloud">
                                @RenderApprovalStatus(poi)
                                @if (poi.IsActive && VKFoodArea.Web.Models.PoiApprovalStatus.IsApproved(poi.ApprovalStatus))
                                {
                                    <span class="status-pill status-pill--success">Đang hoạt động</span>
                                }
                                else
                                {
                                    <span class="status-pill status-pill--muted">Đang ẩn</span>
                                }
                            </div>
                        </div>

                        <div class="inventory-card__stats">
                            <div class="inventory-stat">
                                <strong>Tọa độ</strong>
                                <span class="mono">@poi.Latitude.ToString("0.######"), @poi.Longitude.ToString("0.######")</span>
                            </div>
                            <div class="inventory-stat">
                                <strong>Bán kính</strong>
                                <span>@poi.RadiusMeters.ToString("0.#") m</span>
                            </div>
                            <div class="inventory-stat">
                                <strong>Ngôn ngữ</strong>
                                <span>@(languages.Count == 0 ? "Chưa có" : string.Join(" · ", languages))</span>
                            </div>
                            <div class="inventory-stat">
                                <strong>Ưu tiên</strong>
                                <span>@poi.Priority</span>
                            </div>
                        </div>

                        <div class="pill-cloud">
                            @foreach (var lang in languages)
                            {
                                <span class="lang-pill">@lang</span>
                            }
                        </div>

                        <div class="inventory-card__actions">
                            @if (Model.IsAdmin && VKFoodArea.Web.Models.PoiApprovalStatus.Normalize(poi.ApprovalStatus) == VKFoodArea.Web.Models.PoiApprovalStatus.Pending)
                            {
                                <form asp-action="Approve" asp-route-id="@poi.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-primary btn-sm">Phê duyệt</button>
                                </form>
                                <form asp-action="Reject" asp-route-id="@poi.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Từ chối</button>
                                </form>
                            }
                            <button type="button"
                                    class="audio-preview-button"
                                    data-audio="@VietnameseAudio(poi)"
                                    data-text="@poi.TtsScriptVi"
                                    data-title="@poi.Name"
                                    aria-label="Nghe thử @poi.Name">
                                <span class="audio-preview-button__icon" aria-hidden="true"></span>
                                <span>Nghe thử</span>
                            </button>
                            <a asp-action="Edit" asp-route-id="@poi.Id" class="btn btn-outline-secondary btn-sm">Sửa</a>
                            <a asp-action="Delete" asp-route-id="@poi.Id" class="btn btn-outline-danger btn-sm">Xóa</a>
                        </div>
                    </div>
                </article>
            }
        </div>
    }
</section>

@functions {
    private static Microsoft.AspNetCore.Html.IHtmlContent RenderApprovalStatus(VKFoodArea.Web.Models.Poi poi)
    {
        var status = VKFoodArea.Web.Models.PoiApprovalStatus.Normalize(poi.ApprovalStatus);
        var label = VKFoodArea.Web.Models.PoiApprovalStatus.DisplayName(status);
        var cssClass = status switch
        {
            VKFoodArea.Web.Models.PoiApprovalStatus.Pending => "status-pill status-pill--info",
            VKFoodArea.Web.Models.PoiApprovalStatus.Rejected => "status-pill status-pill--muted",
            _ => "status-pill status-pill--success"
        };

        return new Microsoft.AspNetCore.Html.HtmlString($"<span class=\"{cssClass}\">{label}</span>");
    }

    private static List<string> GetLanguageCodes(VKFoodArea.Web.Models.Poi poi)
    {
        var result = new List<string>();

        if (!string.IsNullOrWhiteSpace(poi.TtsScriptVi)) result.Add("VI");
        if (!string.IsNullOrWhiteSpace(poi.TtsScriptEn)) result.Add("EN");
        if (!string.IsNullOrWhiteSpace(poi.TtsScriptZh)) result.Add("ZH");
        if (!string.IsNullOrWhiteSpace(poi.TtsScriptJa)) result.Add("JA");
        if (!string.IsNullOrWhiteSpace(poi.TtsScriptDe)) result.Add("DE");

        return result;
    }

    private static string VietnameseAudio(VKFoodArea.Web.Models.Poi poi)
        => string.IsNullOrWhiteSpace(poi.AudioFileVi) ? string.Empty : poi.AudioFileVi;

    private static string ResolveImageUrl(string? imageUrl)
    {
        var normalized = (imageUrl ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(normalized))
            return string.Empty;

        if (Uri.TryCreate(normalized, UriKind.Absolute, out _))
            return normalized;

        if (normalized.StartsWith("/", StringComparison.Ordinal))
            return normalized;

        if (normalized.StartsWith("uploads/", StringComparison.OrdinalIgnoreCase))
            return $"/{normalized.TrimStart('/')}";

        return $"/uploads/poi-images/{System.IO.Path.GetFileName(normalized)}";
    }
}

@section Scripts {
    <script>
        (() => {
            let currentAudio = null;

            document.querySelectorAll(".audio-preview-button").forEach((button) => {
                button.addEventListener("click", () => {
                    const audioUrl = button.dataset.audio || "";
                    const text = button.dataset.text || "";

                    if (currentAudio) {
                        currentAudio.pause();
                        currentAudio = null;
                    }

                    if (window.speechSynthesis) {
                        window.speechSynthesis.cancel();
                    }

                    if (audioUrl) {
                        currentAudio = new Audio(audioUrl);
                        currentAudio.play().catch(() => {
                            button.classList.add("audio-preview-button--error");
                        });
                        return;
                    }

                    if (text && window.speechSynthesis) {
                        const utterance = new SpeechSynthesisUtterance(text);
                        utterance.lang = "vi-VN";
                        utterance.rate = 0.9;
                        utterance.pitch = 0.95;
                        window.speechSynthesis.speak(utterance);
                    }
                });
            });
        })();
    </script>
}
