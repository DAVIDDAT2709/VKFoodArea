@model VKFoodArea.Web.ViewModels.PoiFormViewModel
@{
    ViewData["Title"] = "Tạo POI";
}

<section class="page-intro page-section">
    <div>
        <span class="eyebrow">Thêm dữ liệu mới</span>
        <h2>Tạo một POI để app có thể phát thuyết minh theo vị trí hoặc QR</h2>
        <p>Biểu mẫu được chia theo từng nhóm để nhập nhanh hơn: mô tả, geofence, QR và script đa ngôn ngữ.</p>
    </div>
</section>

<form asp-action="Create" method="post" class="stack-gap page-section">
    <partial name="_Form" model="Model" />

    <div class="page-actions">
        <button type="submit" class="btn btn-primary">Lưu POI</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Quay lại danh sách</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
