@model VKFoodArea.Web.Models.Poi
@{
    ViewData["Title"] = "Xóa POI";
}

<div class="card shadow-sm border-0">
    <div class="card-body">
        <h1 class="h4 text-danger">Xác nhận xóa POI</h1>
        <p class="mb-4">Bạn có chắc muốn xóa địa điểm <strong>@Model.Name</strong> không?</p>

        <dl class="row mb-0">
            <dt class="col-sm-3">Địa chỉ</dt>
            <dd class="col-sm-9">@Model.Address</dd>

            <dt class="col-sm-3">Tọa độ</dt>
            <dd class="col-sm-9">@Model.Latitude, @Model.Longitude</dd>
        </dl>
    </div>
    <div class="card-footer bg-white d-flex justify-content-end gap-2">
        <a asp-action="Index" class="btn btn-light">Hủy</a>
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Xóa</button>
        </form>
    </div>
</div>
