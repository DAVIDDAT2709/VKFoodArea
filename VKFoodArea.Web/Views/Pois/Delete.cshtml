@model VKFoodArea.Web.Models.Poi
@{
    ViewData["Title"] = "Xóa POI";
}

<section class="page-header page-section">
    <div>
        <h2>Xóa POI</h2>
    </div>
</section>

<section class="card-surface page-section">
    <div class="delete-grid">
        <div>
            <h3>@Model.Name</h3>
            <p class="text-muted mb-4">@Model.Address</p>

            <div class="list-stack">
                <div class="list-row">
                    <div class="list-row__content">
                        <strong>Tọa độ</strong>
                        <p>@Model.Latitude.ToString("0.######"), @Model.Longitude.ToString("0.######")</p>
                    </div>
                </div>
                <div class="list-row">
                    <div class="list-row__content">
                        <strong>Bán kính</strong>
                        <p>@Model.RadiusMeters.ToString("0.#") m</p>
                    </div>
                </div>
                <div class="list-row">
                    <div class="list-row__content">
                        <strong>QR</strong>
                        <p>@(string.IsNullOrWhiteSpace(Model.QrCode) ? "Chưa có" : Model.QrCode)</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="warning-panel">
            <h3>Xác nhận xóa</h3>
            <div class="page-actions">
                <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger">Xóa POI</button>
                </form>
            </div>
        </div>
    </div>
</section>
