@model VKFoodArea.Web.ViewModels.AdminMapViewModel
@{
    ViewData["Title"] = "Bản đồ POI";

    var poisJson = System.Text.Json.JsonSerializer.Serialize(Model.ActivePois);
    var routesJson = System.Text.Json.JsonSerializer.Serialize(Model.Analytics.Routes);
    var heatmapJson = System.Text.Json.JsonSerializer.Serialize(Model.Analytics.HeatmapPoints);
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<section class="page-header page-section">
    <div>
        <h2>Bản đồ POI</h2>
    </div>
    <div class="page-actions">
        <a asp-controller="NarrationHistories" asp-action="Index" class="btn btn-outline-secondary">Lịch sử nghe</a>
        <a asp-controller="Pois" asp-action="Index" class="btn btn-primary">Danh sách POI</a>
    </div>
</section>

<section class="metrics-grid page-section">
    <article class="metric-card metric-card--blue">
        <span class="metric-card__label">POI hoạt động</span>
        <strong class="metric-card__value">@Model.ActivePois.Count</strong>
    </article>
    <article class="metric-card metric-card--green">
        <span class="metric-card__label">Tuyến ẩn danh</span>
        <strong class="metric-card__value">@Model.Analytics.AnonymousRouteCount</strong>
    </article>
    <article class="metric-card metric-card--orange">
        <span class="metric-card__label">Thiết bị ghi nhận</span>
        <strong class="metric-card__value">@Model.Analytics.AnonymousVisitorCount</strong>
    </article>
    <article class="metric-card metric-card--red">
        <span class="metric-card__label">Điểm nóng</span>
        <strong class="metric-card__value">@Model.Analytics.HeatmapPoints.Count</strong>
    </article>
</section>

<section class="dashboard-grid page-section">
    <article class="card-surface card-surface--accent">
        <div class="section-heading">
            <h2>Bản đồ theo dõi</h2>
            <span class="soft-pill soft-pill--neutral">
                @(Model.Analytics.LatestMovementAt.HasValue
                    ? $"Cập nhật {Model.Analytics.LatestMovementAt.Value:dd/MM HH:mm}"
                    : Model.Analytics.AnalyticsWindowLabel)
            </span>
        </div>

        @if (!Model.HasMapData)
        {
            <div class="empty-state">
                <p>Chưa có dữ liệu để hiển thị trên bản đồ.</p>
            </div>
        }
        else
        {
            <div id="admin-poi-map" class="admin-poi-map" aria-label="Bản đồ POI"></div>
            <div id="admin-map-fallback" class="empty-state mt-3 d-none">
                <p>Không tải được nền bản đồ. Dữ liệu tổng hợp vẫn hiển thị ở cột bên phải.</p>
            </div>
            <div id="admin-heatmap-warning" class="map-insight-note d-none">
                Không tải được lớp heatmap. Tuyến đi và marker POI vẫn hiển thị bình thường.
            </div>
        }
    </article>

    <div class="stacked-panels">
        <article class="card-surface">
            <div class="section-heading">
                <h2>Điểm được nghe nhiều</h2>
            </div>

            @if (!Model.Analytics.TopPois.Any())
            {
                <div class="empty-state">
                    <p>Chưa có dữ liệu lượt nghe.</p>
                </div>
            }
            else
            {
                <div class="list-stack">
                    @foreach (var poi in Model.Analytics.TopPois)
                    {
                        <div class="list-row">
                            <div class="list-row__content">
                                <strong>@poi.PoiName</strong>
                                <p>Cập nhật @poi.LatestPlayedAt.ToString("dd/MM HH:mm")</p>
                            </div>
                            <span class="status-pill status-pill--info">@poi.Count lượt</span>
                        </div>
                    }
                </div>
            }
        </article>

        <article class="card-surface">
            <div class="section-heading">
                <h2>Tuyến gần đây</h2>
            </div>

            @if (!Model.Analytics.Routes.Any())
            {
                <div class="empty-state">
                    <p>Chưa có dữ liệu tuyến đi.</p>
                </div>
            }
            else
            {
                <div class="list-stack">
                    @foreach (var route in Model.Analytics.Routes.OrderByDescending(x => x.EndedAt))
                    {
                        <div class="list-row">
                            <div class="list-row__content">
                                <strong>@route.RouteLabel</strong>
                                <p>@route.PointCount điểm · @Math.Round(route.ApproxDistanceMeters)m · @Math.Round(route.DurationMinutes) phút</p>
                                <p>@route.StartedAt.ToString("dd/MM HH:mm") - @route.EndedAt.ToString("dd/MM HH:mm")</p>
                            </div>
                            <span class="status-pill status-pill--muted">@route.SourceSummary</span>
                        </div>
                    }
                </div>
            }
        </article>

        <article class="card-surface">
            <div class="section-heading">
                <h2>TB nghe / POI</h2>
            </div>

            <div class="stat-box">
                @if (Model.Analytics.AverageListenSeconds > 0)
                {
                    <strong class="stat-box__value">@Math.Round(Model.Analytics.AverageListenSeconds)s</strong>
                    <span class="stat-box__hint">Tính từ các lượt nghe đã đồng bộ và có thời lượng.</span>
                }
                else
                {
                    <strong class="stat-box__value">--</strong>
                    <span class="stat-box__hint">Chưa có dữ liệu thời lượng nghe.</span>
                }
            </div>
        </article>
    </div>
</section>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet.heat/dist/leaflet-heat.js"></script>
    <script>
        (() => {
            const pois = @Html.Raw(poisJson);
            const routes = @Html.Raw(routesJson);
            const heatPoints = @Html.Raw(heatmapJson);
            const mapElement = document.getElementById("admin-poi-map");
            const fallback = document.getElementById("admin-map-fallback");
            const heatWarning = document.getElementById("admin-heatmap-warning");

            if (!mapElement) {
                return;
            }

            if (!window.L) {
                fallback?.classList.remove("d-none");
                return;
            }

            const defaultCenter = [10.7618, 106.7022];
            const map = L.map(mapElement).setView(defaultCenter, 14);
            const bounds = [];
            const routePalette = ["#0f766e", "#2563eb", "#d97706", "#dc2626", "#7c3aed", "#0f766e", "#be185d"];

            L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
                maxZoom: 19,
                attribution: "&copy; OpenStreetMap"
            }).addTo(map);

            const poiLayer = L.layerGroup();
            const routeLayer = L.layerGroup();
            let heatLayer = null;

            pois.forEach((poi) => {
                const latLng = [poi.Latitude, poi.Longitude];
                bounds.push(latLng);

                const marker = L.marker(latLng);
                marker.bindPopup(`
                    <strong>${escapeHtml(poi.Name)}</strong><br>
                    ${escapeHtml(poi.Address)}<br>
                    Bán kính: ${formatNumber(poi.RadiusMeters)}m<br>
                    Ưu tiên: ${formatNumber(poi.Priority)}
                `);
                poiLayer.addLayer(marker);

                poiLayer.addLayer(L.circle(latLng, {
                    radius: poi.RadiusMeters,
                    color: "#2563eb",
                    fillColor: "#2563eb",
                    fillOpacity: 0.1,
                    weight: 1
                }));
            });

            routes.forEach((route, index) => {
                if (!Array.isArray(route.Points) || route.Points.length < 2) {
                    return;
                }

                const color = routePalette[index % routePalette.length];
                const latLngs = route.Points.map((point) => [point.Latitude, point.Longitude]);
                latLngs.forEach((point) => bounds.push(point));

                const polyline = L.polyline(latLngs, {
                    color,
                    weight: 4,
                    opacity: 0.84
                });

                polyline.bindPopup(`
                    <strong>${escapeHtml(route.RouteLabel)}</strong><br>
                    ${escapeHtml(route.SourceSummary)}<br>
                    ${formatNumber(route.PointCount)} điểm · ${formatNumber(route.ApproxDistanceMeters)}m<br>
                    ${formatNumber(route.DurationMinutes)} phút
                `);

                routeLayer.addLayer(polyline);
                routeLayer.addLayer(L.circleMarker(latLngs[0], {
                    radius: 6,
                    color,
                    fillColor: "#ffffff",
                    fillOpacity: 1,
                    weight: 2
                }));
                routeLayer.addLayer(L.circleMarker(latLngs[latLngs.length - 1], {
                    radius: 5,
                    color,
                    fillColor: color,
                    fillOpacity: 0.95,
                    weight: 1
                }));
            });

            if (typeof L.heatLayer === "function" && Array.isArray(heatPoints) && heatPoints.length > 0) {
                heatLayer = L.heatLayer(
                    heatPoints.map((point) => [point.Latitude, point.Longitude, point.Weight]),
                    {
                        radius: 26,
                        blur: 22,
                        maxZoom: 17,
                        minOpacity: 0.35,
                        gradient: {
                            0.25: "#60a5fa",
                            0.45: "#14b8a6",
                            0.7: "#f59e0b",
                            1.0: "#ef4444"
                        }
                    });

                heatPoints.forEach((point) => bounds.push([point.Latitude, point.Longitude]));
            } else if (Array.isArray(heatPoints) && heatPoints.length > 0) {
                heatWarning?.classList.remove("d-none");
            }

            if (poiLayer.getLayers().length > 0) {
                poiLayer.addTo(map);
            }

            if (routeLayer.getLayers().length > 0) {
                routeLayer.addTo(map);
            }

            if (heatLayer) {
                heatLayer.addTo(map);
            }

            const overlayLayers = {};
            if (poiLayer.getLayers().length > 0) {
                overlayLayers["POI hoạt động"] = poiLayer;
            }
            if (routeLayer.getLayers().length > 0) {
                overlayLayers["Tuyến ẩn danh"] = routeLayer;
            }
            if (heatLayer) {
                overlayLayers["Điểm nóng"] = heatLayer;
            }

            if (Object.keys(overlayLayers).length > 0) {
                L.control.layers(null, overlayLayers, {
                    collapsed: false,
                    position: "topright"
                }).addTo(map);
            }

            if (bounds.length > 1) {
                map.fitBounds(bounds, { padding: [28, 28] });
            } else if (bounds.length === 1) {
                map.setView(bounds[0], 16);
            }

            function escapeHtml(value) {
                return String(value ?? "")
                    .replaceAll("&", "&amp;")
                    .replaceAll("<", "&lt;")
                    .replaceAll(">", "&gt;")
                    .replaceAll('"', "&quot;")
                    .replaceAll("'", "&#039;");
            }

            function formatNumber(value) {
                const numericValue = Number(value ?? 0);
                return new Intl.NumberFormat("vi-VN", {
                    maximumFractionDigits: numericValue >= 100 ? 0 : 1
                }).format(numericValue);
            }
        })();
    </script>
}
