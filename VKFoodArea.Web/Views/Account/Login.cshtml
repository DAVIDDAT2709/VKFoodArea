@model VKFoodArea.Web.ViewModels.AdminLoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập quản trị - VK Food Area</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="auth-page auth-page--admin">
    <main class="admin-login-shell" aria-label="Đăng nhập khu vực quản trị">
        <section class="admin-login-hero" aria-label="Giới thiệu khu vực quản trị">
            <div class="admin-login-brand">
                <span class="admin-login-logo">VK</span>
                <div>
                    <p>VK Food Area</p>
                    <strong>Khu vực quản trị</strong>
                </div>
            </div>

            <div class="admin-login-copy">
                <span class="soft-pill soft-pill--glass">Admin</span>
                <h1>Quản lý POI, tour, mã QR và dữ liệu nghe trên một giao diện.</h1>
                <p>Đăng nhập để tiếp tục vào trang điều hành.</p>
            </div>

            <div class="admin-login-signal" aria-label="Chức năng chính">
                <div>
                    <span>01</span>
                    <strong>POI</strong>
                    <p>Quản lý ảnh, vị trí và nội dung TTS.</p>
                </div>
                <div>
                    <span>02</span>
                    <strong>QR</strong>
                    <p>Tạo mã mới và gắn trực tiếp với POI hoặc tour.</p>
                </div>
                <div>
                    <span>03</span>
                    <strong>Báo cáo</strong>
                    <p>Theo dõi lịch sử nghe và dữ liệu bản đồ.</p>
                </div>
            </div>
        </section>

        <section class="admin-login-panel" aria-label="Form đăng nhập admin">
            <div class="admin-login-panel__head">
                <span class="soft-pill">Đăng nhập</span>
                <h2>Quản trị viên</h2>
                <p>Nhập tài khoản để tiếp tục.</p>
            </div>

            <form asp-action="Login" method="post" class="admin-login-form" novalidate>
                <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
                <input asp-for="ReturnUrl" type="hidden" />

                <div class="auth-field">
                    <label asp-for="Username" class="form-label"></label>
                    <input asp-for="Username" class="form-control" autocomplete="username" autofocus />
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" autocomplete="current-password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="admin-login-options">
                    <div class="form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label"></label>
                    </div>
                </div>

                <button type="submit" class="auth-submit">Đăng nhập</button>
            </form>
        </section>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
