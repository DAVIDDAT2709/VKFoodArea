@model VKFoodArea.Web.ViewModels.QrCodeItemFormViewModel

<div asp-validation-summary="ModelOnly" class="validation-summary"></div>

<section class="card-surface">
    <div class="section-heading">
        <h2>Thông tin mã QR</h2>
    </div>

    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="Code" class="form-label"></label>
            <input asp-for="Code" class="form-control" placeholder="Ví dụ: qr-oc-sau-no" />
            <span asp-validation-for="Code" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Title" class="form-label"></label>
            <input asp-for="Title" class="form-control" placeholder="Tên hiển thị" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="ImageFile" class="form-label"></label>
            <input asp-for="ImageFile" class="form-control" type="file" accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" />
            <span asp-validation-for="ImageFile" class="text-danger"></span>
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.CurrentImageUrl))
        {
            <div class="col-md-6">
                <label class="form-label">Ảnh hiện tại</label>
                <div class="qr-preview">
                    <img src="@Model.CurrentImageUrl" alt="QR @Model.Title" />
                </div>
            </div>
        }
        <div class="col-md-4">
            <label asp-for="TargetType" class="form-label"></label>
            <select asp-for="TargetType" asp-items="Model.TargetTypeOptions" class="form-select" id="qr-target-type"></select>
            <span asp-validation-for="TargetType" class="text-danger"></span>
        </div>
        <div class="col-md-4" data-target-panel="poi">
            <label asp-for="PoiId" class="form-label"></label>
            <select asp-for="PoiId" asp-items="Model.PoiOptions" class="form-select">
                <option value="">-- Chọn POI --</option>
            </select>
            <span asp-validation-for="PoiId" class="text-danger"></span>
        </div>
        <div class="col-md-4" data-target-panel="tour">
            <label asp-for="TourId" class="form-label"></label>
            <select asp-for="TourId" asp-items="Model.TourOptions" class="form-select">
                <option value="">-- Chọn tour --</option>
            </select>
            <span asp-validation-for="TourId" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <div class="form-check form-switch field-switch">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label"></label>
            </div>
        </div>
    </div>
</section>

<script>
    (() => {
        const select = document.getElementById("qr-target-type");
        const panels = document.querySelectorAll("[data-target-panel]");

        function syncTargetPanels() {
            const current = (select?.value || "poi").toLowerCase();
            panels.forEach((panel) => {
                panel.style.display = panel.getAttribute("data-target-panel") === current ? "" : "none";
            });
        }

        if (select) {
            select.addEventListener("change", syncTargetPanels);
            syncTargetPanels();
        }
    })();
</script>
