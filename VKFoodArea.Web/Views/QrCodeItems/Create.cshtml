@model VKFoodArea.Web.ViewModels.QrCodeItemFormViewModel
@{
    ViewData["Title"] = "Tạo QR code";
}

<section class="page-intro page-section">
    <div>
        <span class="eyebrow">Tạo mã mới</span>
        <h2>Thêm QR để người dùng kích hoạt nội dung ngay tại điểm chạm</h2>
        <p>Phù hợp cho các điểm dừng, quầy hàng hoặc bảng thông tin trong khu ẩm thực.</p>
    </div>
</section>

<form asp-action="Create" method="post" class="stack-gap page-section">
    <partial name="_Form" model="Model" />

    <div class="page-actions">
        <button type="submit" class="btn btn-primary">Lưu QR</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Quay lại danh sách</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
