@model VKFoodArea.Web.ViewModels.QrCodeItemFormViewModel
@{
    ViewData["Title"] = "Tạo mã QR";
}

<section class="page-header page-section">
    <div>
        <h2>Tạo mã QR</h2>
    </div>
</section>

<form asp-action="Create" method="post" enctype="multipart/form-data" class="stack-gap page-section">
    <partial name="_Form" model="Model" />

    <div class="page-actions">
        <button type="submit" class="btn btn-primary">Lưu mã QR</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Quay lại</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
