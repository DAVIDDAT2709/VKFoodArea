@model VKFoodArea.Web.ViewModels.QrCodeItemDeleteViewModel
@{
    ViewData["Title"] = "Xóa QR code";
}

<section class="page-header page-section">
    <div>
        <h2>Xóa QR code</h2>
    </div>
</section>

<section class="card-surface page-section">
    <div class="delete-grid">
        <div>
            <h3>@Model.Title</h3>
            <div class="list-stack">
                <div class="list-row">
                    <div class="list-row__content">
                        <strong>Mã QR</strong>
                        <p class="mono">@Model.Code</p>
                    </div>
                </div>
                <div class="list-row">
                    <div class="list-row__content">
                        <strong>Target</strong>
                        <p>@Model.TargetName (@Model.TargetType.ToUpperInvariant() #@Model.TargetId)</p>
                    </div>
                </div>
                <div class="list-row">
                    <div class="list-row__content">
                        <strong>Ngày tạo</strong>
                        <p>@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="warning-panel">
            <h3>Xác nhận xóa</h3>
            <div class="page-actions">
                <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger">Xóa QR</button>
                </form>
            </div>
        </div>
    </div>
</section>
