@model IEnumerable<VKFoodArea.Web.ViewModels.QrCodeItemListItemViewModel>
@inject IConfiguration Configuration
@{
    ViewData["Title"] = "Mã QR";
    var items = Model.ToList();
    var activeCount = items.Count(x => x.IsActive);
    var coveredPoiCount = items.Count(x => string.Equals(x.TargetType, "poi", StringComparison.OrdinalIgnoreCase));
    var coveredTourCount = items.Count(x => string.Equals(x.TargetType, "tour", StringComparison.OrdinalIgnoreCase));
    var configuredBaseUrl = (Configuration["PublicBaseUrl"] ?? string.Empty).Trim();
    var forwardedScheme = Context.Request.Headers["X-Forwarded-Proto"].FirstOrDefault();
    var scheme = string.IsNullOrWhiteSpace(forwardedScheme) ? Context.Request.Scheme : forwardedScheme;
    var requestBaseUrl = $"{scheme}://{Context.Request.Host}".TrimEnd('/');
    var baseUrl = (string.IsNullOrWhiteSpace(configuredBaseUrl) ? requestBaseUrl : configuredBaseUrl).TrimEnd('/');
}

<section class="page-header page-section">
    <div>
        <h2>Mã QR</h2>
    </div>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary">Tạo mã QR</a>
    </div>
</section>

<section class="metrics-grid page-section">
    <article class="metric-card metric-card--blue">
        <span class="metric-card__label">Tổng mã</span>
        <strong class="metric-card__value">@items.Count</strong>
    </article>
    <article class="metric-card metric-card--green">
        <span class="metric-card__label">Đang hoạt động</span>
        <strong class="metric-card__value">@activeCount</strong>
    </article>
    <article class="metric-card metric-card--orange">
        <span class="metric-card__label">Liên kết POI</span>
        <strong class="metric-card__value">@coveredPoiCount</strong>
    </article>
    <article class="metric-card metric-card--red">
        <span class="metric-card__label">Liên kết Tour</span>
        <strong class="metric-card__value">@coveredTourCount</strong>
    </article>
</section>

<section class="card-surface page-section">
    <div class="section-heading">
        <h2>Kho mã QR</h2>
    </div>

    @if (!items.Any())
    {
        <div class="empty-state">
            <p>Chưa có mã QR.</p>
        </div>
    }
    else
    {
        <div class="inventory-grid">
            @foreach (var item in items)
            {
                <article class="inventory-card qr-card">
                    <div class="inventory-card__media">
                        @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" alt="Mã QR @item.Title" />
                        }
                        else
                        {
                            <div class="inventory-card__placeholder">QR</div>
                        }
                    </div>

                    <div class="inventory-card__body">
                        <div class="inventory-card__header">
                            <div>
                                <div class="inventory-card__title">@item.Title</div>
                                <div class="inventory-card__meta">@item.TargetName</div>
                            </div>
                            @if (item.IsActive)
                            {
                                <span class="status-pill status-pill--success">Đang hoạt động</span>
                            }
                            else
                            {
                                <span class="status-pill status-pill--muted">Đang ẩn</span>
                            }
                        </div>

                        <div class="inventory-card__stats">
                            <div class="inventory-stat">
                                <strong>Mã</strong>
                                <span class="mono">@item.Code</span>
                            </div>
                            <div class="inventory-stat">
                                <strong>Liên kết mở app</strong>
                                <span class="mono">@($"{baseUrl}/qr/{Uri.EscapeDataString(item.Code)}")</span>
                            </div>
                            <div class="inventory-stat">
                                <strong>Đích đến</strong>
                                <span>@item.TargetType.ToUpperInvariant() #@item.TargetId</span>
                            </div>
                            <div class="inventory-stat">
                                <strong>Ngày tạo</strong>
                                <span>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                        </div>

                        <div class="inventory-card__actions">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm">Sửa</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">Xóa</a>
                        </div>
                    </div>
                </article>
            }
        </div>
    }
</section>
