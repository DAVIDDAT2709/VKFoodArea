@model VKFoodArea.Web.ViewModels.HomeDashboardViewModel
@{
    ViewData["Title"] = "Tổng quan";
}

<section class="metrics-grid page-section">
    <article class="metric-card metric-card--green">
        <span class="metric-card__label">Thiết bị đang hoạt động</span>
        <strong class="metric-card__value" id="active-device-count">@Model.ActiveDeviceCount</strong>
        <span class="metric-card__footer">
            <span id="active-user-count">@Model.ActiveUserCount</span> người dùng online
        </span>
    </article>
    <article class="metric-card metric-card--blue">
        <span class="metric-card__label">POI hoạt động</span>
        <strong class="metric-card__value">@Model.ActivePoiCount / @Model.PoiCount</strong>
    </article>
    <article class="metric-card metric-card--green">
        <span class="metric-card__label">Mã QR đang bật</span>
        <strong class="metric-card__value">@Model.ActiveQrCount</strong>
    </article>
    <article class="metric-card metric-card--orange">
        <span class="metric-card__label">Lượt nghe hôm nay</span>
        <strong class="metric-card__value">@Model.TodayNarrationCount</strong>
    </article>
    <article class="metric-card metric-card--red">
        <span class="metric-card__label">Ngôn ngữ</span>
        <strong class="metric-card__value">@Model.ConfiguredLanguageCount</strong>
    </article>
    <article class="metric-card metric-card--blue">
        <span class="metric-card__label">Tour hoạt động</span>
        <strong class="metric-card__value">@Model.ActiveTourCount</strong>
    </article>
    <article class="metric-card metric-card--green">
        <span class="metric-card__label">Tổng lượt nghe</span>
        <strong class="metric-card__value">@Model.NarrationHistoryCount</strong>
    </article>
</section>

<section class="dashboard-grid page-section">
    <article class="card-surface">
        <div class="section-heading">
            <h2>Tóm tắt dữ liệu</h2>
        </div>

        <div class="summary-list">
            <div class="summary-row">
                <span>POI</span>
                <strong>@Model.PoiCount</strong>
            </div>
            <div class="summary-row">
                <span>Mã QR đang bật</span>
                <strong>@Model.ActiveQrCount</strong>
            </div>
            <div class="summary-row">
                <span>Nguồn phát sinh</span>
                <strong>@Model.GpsNarrationCount / @Model.QrNarrationCount / @Model.ManualNarrationCount</strong>
            </div>
        </div>
    </article>

    <article class="card-surface">
        <div class="section-heading">
            <h2>Ngôn ngữ đang dùng</h2>
        </div>

        @if (!Model.LanguageBreakdown.Any())
        {
            <div class="empty-state">
                <p>Chưa có dữ liệu.</p>
            </div>
        }
        else
        {
            <div class="pill-cloud">
                @foreach (var item in Model.LanguageBreakdown)
                {
                    <span class="soft-pill">@item.Label: @item.Count</span>
                }
            </div>
        }
    </article>
</section>

<section class="dashboard-panels page-section">
    <article class="card-surface">
        <div class="section-heading">
            <h2>Điểm được nghe nhiều</h2>
        </div>

        @if (!Model.TopPois.Any())
        {
            <div class="empty-state">
                <p>Chưa có dữ liệu.</p>
            </div>
        }
        else
        {
            <div class="list-stack">
                @foreach (var item in Model.TopPois.Take(5))
                {
                    <div class="list-row">
                        <div class="list-row__content">
                            <strong>@item.PoiName</strong>
                            <p>Cập nhật @WebDisplayTime.Format(item.LatestPlayedAt, "dd/MM HH:mm")</p>
                        </div>
                        <span class="status-pill status-pill--info">@item.Count lượt</span>
                    </div>
                }
            </div>
        }
    </article>

    <article class="card-surface">
        <div class="section-heading">
            <h2>TB nghe / POI</h2>
        </div>

        <div class="stat-box">
            <span class="stat-box__label">Thời lượng trung bình</span>
            @if (Model.AverageListenSampleCount > 0)
            {
                <strong class="stat-box__value">@Math.Round(Model.AverageListenSeconds)s</strong>
                <span class="stat-box__hint">@Model.AverageListenSampleCount lượt đã ghi nhận thời lượng.</span>
            }
            else
            {
                <strong class="stat-box__value">--</strong>
                <span class="stat-box__hint">Chưa có lượt nghe nào ghi nhận thời lượng.</span>
            }
        </div>
    </article>
</section>

<section class="card-surface page-section">
    <div class="section-heading">
        <h2>Lượt nghe gần đây</h2>
    </div>

    @if (!Model.RecentNarrations.Any())
    {
        <div class="empty-state">
            <p>Chưa có dữ liệu.</p>
        </div>
    }
    else
    {
        <div class="list-stack">
            @foreach (var item in Model.RecentNarrations.Take(6))
            {
                <div class="list-row">
                    <div class="list-row__content">
                        <strong>@item.PoiName</strong>
                        <p>@item.Language.ToUpperInvariant() · @MapSource(item.TriggerSource) · @item.Mode.ToUpperInvariant()
                        </p>
                    </div>
                    <span class="status-pill status-pill--muted">@WebDisplayTime.Format(item.PlayedAt, "dd/MM HH:mm")</span>
                </div>
            }
        </div>
    }
</section>
<section class="card-surface page-section">
    <div class="section-heading">
        <h2>Thiết bị online realtime</h2>
        <span class="soft-pill">Timeout @Model.DeviceTimeoutSeconds giây</span>
    </div>

    <div class="list-stack" id="active-device-list">
        @if (!Model.ActiveDevices.Any())
        {
            <div class="empty-state">
                <p>Chưa có thiết bị online.</p>
            </div>
        }
        else
        {
            @foreach (var item in Model.ActiveDevices)
            {
                <div class="list-row">
                    <div class="list-row__content">
                        <strong>@(string.IsNullOrWhiteSpace(item.FullName) ? item.DeviceName : item.FullName)</strong>
                        <p>@item.Platform · @item.DeviceName · v@item.AppVersion</p>
                    </div>
                    <span class="status-pill status-pill--info">
                        @WebDisplayTime.Format(item.LastHeartbeatAt, "dd/MM HH:mm:ss")
                    </span>
                </div>
            }
        }
    </div>
</section>
@section Scripts {
    <script>
        const activeDeviceCountEl = document.getElementById('active-device-count');
        const activeUserCountEl = document.getElementById('active-user-count');
        const activeDeviceListEl = document.getElementById('active-device-list');

        function escapeHtml(value) {
            return (value ?? '').replace(/[&<>"']/g, m => ({
                '&': '&amp;',
                '<': '&lt;',
                '>': '&gt;',
                '"': '&quot;',
                "'": '&#39;'
            }[m]));
        }

        async function refreshActiveDevices() {
            try {
                const response = await fetch('@Url.Action("ActiveDevices", "Home")', {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });

                if (!response.ok) return;

                const data = await response.json();

                if (activeDeviceCountEl)
                    activeDeviceCountEl.textContent = data.activeDeviceCount ?? 0;

                if (activeUserCountEl)
                    activeUserCountEl.textContent = data.activeUserCount ?? 0;

                if (!activeDeviceListEl) return;

                if (!data.devices || data.devices.length === 0) {
                    activeDeviceListEl.innerHTML = '<div class="empty-state"><p>Chưa có thiết bị online.</p></div>';
                    return;
                }

                activeDeviceListEl.innerHTML = data.devices.map(item => `
                    <div class="list-row">
                        <div class="list-row__content">
                            <strong>${escapeHtml(item.fullName || item.deviceName || 'Thiết bị')}</strong>
                            <p>${escapeHtml(item.platform || '')} · ${escapeHtml(item.deviceName || '')} · v${escapeHtml(item.appVersion || '')}</p>
                        </div>
                        <span class="status-pill status-pill--info">
                            ${escapeHtml(item.lastHeartbeatDisplay || '')}
                        </span>
                    </div>
                `).join('');
            } catch {
            }
        }

        refreshActiveDevices();
        setInterval(refreshActiveDevices, 5000);
    </script>
}

@functions {
    private static string MapSource(string source)
        => (source ?? string.Empty).Trim().ToLowerInvariant() switch
        {
            "gps" => "GPS",
            "auto" => "GPS",
            "qr" => "QR",
            "manual" => "Thủ công",
            _ => "Khác"
        };
}
