@model VKFoodArea.Web.ViewModels.HomeDashboardViewModel
@{
    ViewData["Title"] = "Tổng quan";
}

<section class="page-header page-section">
    <div>
        <h2>Dashboard</h2>
    </div>
    <div class="page-actions">
        <a asp-controller="Pois" asp-action="Create" class="btn btn-primary">Thêm POI</a>
        <a asp-controller="NarrationHistories" asp-action="Index" class="btn btn-outline-secondary">Xem log</a>
    </div>
</section>

<section class="page-grid page-section">
    <article class="card-surface">
        <div class="section-heading">
            <h2>Nguon kich hoat</h2>
        </div>
        @if (!Model.TriggerSourceBreakdown.Any())
        {
            <div class="empty-state">
                <p>Chua co du lieu.</p>
            </div>
        }
        else
        {
            <div class="pill-cloud">
                @foreach (var item in Model.TriggerSourceBreakdown)
                {
                    <span class="soft-pill">@item.Label: @item.Count</span>
                }
            </div>
        }
    </article>

    <article class="card-surface">
        <div class="section-heading">
            <h2>Che do phat</h2>
        </div>
        @if (!Model.PlaybackModeBreakdown.Any())
        {
            <div class="empty-state">
                <p>Chua co du lieu.</p>
            </div>
        }
        else
        {
            <div class="pill-cloud">
                @foreach (var item in Model.PlaybackModeBreakdown)
                {
                    <span class="soft-pill">@item.Label: @item.Count</span>
                }
            </div>
        }
    </article>
</section>

<section class="metrics-grid page-section">
    <article class="metric-card metric-card--blue">
        <span class="metric-card__label">POI hoạt động</span>
        <strong class="metric-card__value">@Model.ActivePoiCount / @Model.PoiCount</strong>
    </article>
    <article class="metric-card metric-card--green">
        <span class="metric-card__label">QR đang dùng</span>
        <strong class="metric-card__value">@(Model.DefaultQrCount + Model.ActiveQrCount)</strong>
    </article>
    <article class="metric-card metric-card--orange">
        <span class="metric-card__label">Lượt nghe hôm nay</span>
        <strong class="metric-card__value">@Model.TodayNarrationCount</strong>
    </article>
    <article class="metric-card metric-card--red">
        <span class="metric-card__label">Ngôn ngữ</span>
        <strong class="metric-card__value">@Model.ConfiguredLanguageCount</strong>
    </article>
    <article class="metric-card metric-card--blue">
        <span class="metric-card__label">Movement logs</span>
        <strong class="metric-card__value">@Model.MovementLogCount</strong>
    </article>
    <article class="metric-card metric-card--green">
        <span class="metric-card__label">Tour hoạt động</span>
        <strong class="metric-card__value">@Model.ActiveTourCount</strong>
    </article>
    <article class="metric-card metric-card--orange">
        <span class="metric-card__label">TB nghe / POI</span>
        <strong class="metric-card__value">@Math.Round(Model.AverageListenSeconds)s</strong>
    </article>
</section>

<section class="dashboard-grid page-section">
    <article class="card-surface">
        <div class="section-heading">
            <h2>Tổng hợp</h2>
        </div>
        <div class="summary-list">
            <div class="summary-row">
                <span>Tổng POI</span>
                <strong>@Model.PoiCount</strong>
            </div>
            <div class="summary-row">
                <span>QR mặc định</span>
                <strong>@Model.DefaultQrCount</strong>
            </div>
            <div class="summary-row">
                <span>QR phụ hoạt động</span>
                <strong>@Model.ActiveQrCount</strong>
            </div>
            <div class="summary-row">
                <span>Tổng log</span>
                <strong>@Model.NarrationHistoryCount</strong>
            </div>
            <div class="summary-row">
                <span>GPS / QR / Manual</span>
                <strong>@Model.GpsNarrationCount / @Model.QrNarrationCount / @Model.ManualNarrationCount</strong>
            </div>
        </div>
    </article>

    <article class="card-surface">
        <div class="section-heading">
            <h2>Top POI</h2>
        </div>
        @if (!Model.TopPois.Any())
        {
            <div class="empty-state">
                <p>Chưa có dữ liệu.</p>
            </div>
        }
        else
        {
            <div class="list-stack">
                @foreach (var item in Model.TopPois.Take(5))
                {
                    <div class="list-row">
                        <div class="list-row__content">
                            <strong>@item.PoiName</strong>
                            <p>POI #@item.PoiId - latest @item.LatestPlayedAt.ToString("dd/MM HH:mm")</p>
                        </div>
                        <span class="status-pill status-pill--info">@item.Count lượt</span>
                    </div>
                }
            </div>
        }
    </article>
</section>

<section class="page-grid page-section">
    <article class="card-surface">
        <div class="section-heading">
            <h2>Lịch sử nghe gần đây</h2>
        </div>
        @if (!Model.RecentNarrations.Any())
        {
            <div class="empty-state">
                <p>Chưa có dữ liệu.</p>
            </div>
        }
        else
        {
            <div class="list-stack">
                @foreach (var item in Model.RecentNarrations.Take(6))
                {
                    <div class="list-row">
                        <div class="list-row__content">
                            <strong>@item.PoiName</strong>
                            <p>POI #@item.PoiId - @item.Language.ToUpperInvariant() - @item.TriggerSource.ToUpperInvariant() - @item.Mode.ToUpperInvariant()</p>
                        </div>
                        <span class="status-pill status-pill--muted">@item.PlayedAt.ToString("dd/MM HH:mm")</span>
                    </div>
                }
            </div>
        }
    </article>

    <article class="card-surface">
        <div class="section-heading">
            <h2>Ngôn ngữ phát</h2>
        </div>
        @if (!Model.LanguageBreakdown.Any())
        {
            <div class="empty-state">
                <p>Chưa có dữ liệu.</p>
            </div>
        }
        else
        {
            <div class="pill-cloud">
                @foreach (var item in Model.LanguageBreakdown)
                {
                    <span class="soft-pill">@item.Label: @item.Count</span>
                }
            </div>
        }
    </article>
</section>
