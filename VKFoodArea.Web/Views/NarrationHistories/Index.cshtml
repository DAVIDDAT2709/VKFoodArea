@model IEnumerable<VKFoodArea.Web.Models.NarrationHistory>
@{
    ViewData["Title"] = "Lịch sử nghe";
    var currentSource = ViewBag.CurrentSource as string;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">Lịch sử nghe</h1>
        <p class="text-muted mb-0">Theo dõi lượt phát thuyết minh từ app người dùng.</p>
    </div>
</div>

<div class="card shadow-sm border-0 mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-sm-4">
                <label class="form-label">Lọc theo nguồn</label>
                <select name="source" class="form-select">
                    <option value="">Tất cả</option>
                    <option value="manual" selected="@(currentSource == "manual")">manual</option>
                    <option value="gps" selected="@(currentSource == "gps")">gps</option>
                    <option value="qr" selected="@(currentSource == "qr")">qr</option>
                </select>
            </div>
            <div class="col-sm-auto">
                <button type="submit" class="btn btn-primary">Lọc</button>
                <a asp-action="Index" class="btn btn-light">Reset</a>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-striped align-middle mb-0">
            <thead>
                <tr>
                    <th>POI</th>
                    <th>Ngôn ngữ</th>
                    <th>Nguồn</th>
                    <th>Chế độ</th>
                    <th>Thời gian</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.PoiName</td>
                    <td>@item.Language</td>
                    <td>@item.TriggerSource</td>
                    <td>@item.Mode</td>
                    <td>@item.PlayedAt.ToString("dd/MM/yyyy HH:mm:ss")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
