@model VKFoodArea.Web.ViewModels.NarrationHistoryIndexViewModel
@{
    ViewData["Title"] = "Lịch sử nghe";
    var items = Model.Items;
}

<section class="page-header page-section">
    <div>
        <h2>Lịch sử nghe</h2>
    </div>
</section>

<section class="metrics-grid page-section">
    <article class="metric-card metric-card--blue">
        <span class="metric-card__label">Tổng lượt nghe</span>
        <strong class="metric-card__value">@items.Count</strong>
    </article>
    <article class="metric-card metric-card--green">
        <span class="metric-card__label">Hôm nay</span>
        <strong class="metric-card__value">@Model.TodayCount</strong>
    </article>
    <article class="metric-card metric-card--orange">
        <span class="metric-card__label">GPS</span>
        <strong class="metric-card__value">@Model.GpsCount</strong>
    </article>
    <article class="metric-card metric-card--red">
        <span class="metric-card__label">QR</span>
        <strong class="metric-card__value">@Model.QrCount</strong>
    </article>
</section>

<section class="card-surface page-section">
    <div class="section-heading">
        <h2>Tìm kiếm nâng cao</h2>
    </div>

    <form method="get" class="search-grid">
        <div class="search-grid__wide">
            <label class="form-label" for="query">Tên quán</label>
            <input id="query" name="query" class="form-control" value="@Model.Query" placeholder="Nhập tên quán hoặc POI" />
        </div>
        <div>
            <label class="form-label" for="fromDate">Từ ngày</label>
            <input id="fromDate" name="fromDate" type="date" class="form-control" value="@Model.FromDate?.ToString("yyyy-MM-dd")" />
        </div>
        <div>
            <label class="form-label" for="toDate">Đến ngày</label>
            <input id="toDate" name="toDate" type="date" class="form-control" value="@Model.ToDate?.ToString("yyyy-MM-dd")" />
        </div>
        <div>
            <label class="form-label" for="language">Ngôn ngữ</label>
            <select id="language" name="language" class="form-select">
                <option value="">Tất cả</option>
                <option value="vi" selected="@(Model.Language == "vi")">VI</option>
                <option value="en" selected="@(Model.Language == "en")">EN</option>
                <option value="zh" selected="@(Model.Language == "zh")">ZH</option>
                <option value="ja" selected="@(Model.Language == "ja")">JA</option>
                <option value="de" selected="@(Model.Language == "de")">DE</option>
            </select>
        </div>
        <div>
            <label class="form-label" for="mode">Kiểu phát</label>
            <select id="mode" name="mode" class="form-select">
                <option value="">Tất cả</option>
                <option value="tts" selected="@(Model.Mode == "tts")">TTS</option>
                <option value="audio" selected="@(Model.Mode == "audio")">Audio</option>
            </select>
        </div>
        <div>
            <label class="form-label" for="source">Nguồn</label>
            <select id="source" name="source" class="form-select">
                <option value="">Tất cả</option>
                <option value="gps" selected="@(Model.Source == "gps")">GPS</option>
                <option value="qr" selected="@(Model.Source == "qr")">QR</option>
                <option value="manual" selected="@(Model.Source == "manual")">Thủ công</option>
            </select>
        </div>
        <div class="search-actions">
            <button type="submit" class="btn btn-primary">Tìm kiếm</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Đặt lại</a>
        </div>
    </form>
</section>

<section class="dashboard-grid page-section">
    <article class="card-surface">
        <div class="section-heading">
            <h2>Điểm được nghe nhiều</h2>
        </div>

        @if (!Model.TopPois.Any())
        {
            <div class="empty-state">
                <p>Chưa có dữ liệu.</p>
            </div>
        }
        else
        {
            <div class="list-stack">
                @foreach (var item in Model.TopPois)
                {
                    <div class="list-row">
                        <div class="list-row__content">
                            <strong>@item.PoiName</strong>
                            <p>@item.LatestPlayedAt.ToString("dd/MM HH:mm")</p>
                        </div>
                        <span class="soft-pill">@item.Count lượt</span>
                    </div>
                }
            </div>
        }
    </article>

    <article class="card-surface">
        <div class="section-heading">
            <h2>Nguồn ghi nhận</h2>
        </div>

        <div class="summary-list">
            <div class="summary-row">
                <span>GPS</span>
                <strong>@Model.GpsCount</strong>
            </div>
            <div class="summary-row">
                <span>QR</span>
                <strong>@Model.QrCount</strong>
            </div>
            <div class="summary-row">
                <span>Thủ công</span>
                <strong>@Model.ManualCount</strong>
            </div>
        </div>
    </article>
</section>

<section class="card-surface page-section">
    <div class="section-heading">
        <h2>Dữ liệu nghe</h2>
    </div>

    @if (!items.Any())
    {
        <div class="empty-state">
            <p>Không có dữ liệu.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table data-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Quán</th>
                        <th>Ngôn ngữ</th>
                        <th>Kiểu phát</th>
                        <th>Nguồn</th>
                        <th>Thời lượng</th>
                        <th>Người dùng</th>
                        <th>Thời gian</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in items)
                {
                    <tr>
                        <td>
                            <div class="table-title">@item.PoiName</div>
                            <div class="table-meta">#@item.PoiId</div>
                        </td>
                        <td><span class="lang-pill">@item.Language.ToUpperInvariant()</span></td>
                        <td>@item.Mode.ToUpperInvariant()</td>
                        <td><span class="status-pill status-pill--info">@MapSource(item.TriggerSource)</span></td>
                        <td>@(item.DurationSeconds.HasValue ? $"{item.DurationSeconds.Value}s" : "-")</td>
                        <td><span class="soft-pill">@(string.IsNullOrWhiteSpace(item.UserKey) ? "Ẩn danh" : item.UserKey)</span></td>
                        <td>@item.PlayedAt.ToString("dd/MM/yyyy HH:mm:ss")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>

@functions {
    private static string MapSource(string source)
        => source?.Trim().ToLowerInvariant() switch
        {
            "gps" => "GPS",
            "auto" => "GPS",
            "qr" => "QR",
            "manual" => "Thủ công",
            _ => "Khác"
        };
}
