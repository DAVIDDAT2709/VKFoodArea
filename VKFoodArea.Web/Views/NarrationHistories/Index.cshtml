@model IEnumerable<VKFoodArea.Web.Models.NarrationHistory>
@{
    ViewData["Title"] = "Lịch sử nghe";
    ViewData["Subtitle"] = "Theo dõi lượt phát, nguồn kích hoạt và hoạt động nghe gần nhất để kiểm tra trải nghiệm thực tế trên app.";
    var currentSource = (ViewBag.CurrentSource as string ?? string.Empty).Trim().ToLowerInvariant();
    var items = Model.ToList();
    var todayCount = items.Count(x => x.PlayedAt >= DateTime.Today);
    var gpsCount = items.Count(x =>
        string.Equals(x.TriggerSource, "gps", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(x.TriggerSource, "auto", StringComparison.OrdinalIgnoreCase));
    var qrCount = items.Count(x => string.Equals(x.TriggerSource, "qr", StringComparison.OrdinalIgnoreCase));
    var topPois = items
        .GroupBy(x => x.PoiId)
        .Select(x => new
        {
            PoiId = x.Key,
            PoiName = x.OrderByDescending(item => item.PlayedAt).First().PoiName,
            Count = x.Count()
        })
        .OrderByDescending(x => x.Count)
        .ThenBy(x => x.PoiName)
        .Take(4)
        .ToList();
    var latestItemId = items.FirstOrDefault()?.Id ?? 0;
}

<section class="page-header page-section">
    <div class="headline-stack">
        <span class="page-kicker">Playback Logs</span>
        <h2>Lịch sử nghe</h2>
        <p class="page-subtitle">Theo dõi dữ liệu phát theo thời gian thực để đối chiếu nhanh giữa app, QR và nội dung đang xuất bản.</p>
    </div>
</section>

<section class="metrics-grid page-section">
    <article class="metric-card metric-card--blue">
        <span class="metric-card__label">Tổng lượt nghe</span>
        <strong class="metric-card__value">@items.Count</strong>
        <span class="metric-card__meta">Tổng số lượt phát hiện có trong tập dữ liệu đang xem.</span>
    </article>
    <article class="metric-card metric-card--green">
        <span class="metric-card__label">Hôm nay</span>
        <strong class="metric-card__value">@todayCount</strong>
        <span class="metric-card__meta">Mức sử dụng mới nhất để kiểm tra nhịp vận hành trong ngày.</span>
    </article>
    <article class="metric-card metric-card--orange">
        <span class="metric-card__label">GPS</span>
        <strong class="metric-card__value">@gpsCount</strong>
        <span class="metric-card__meta">Số lượt phát tự động từ vị trí hoặc geofence.</span>
    </article>
    <article class="metric-card metric-card--red">
        <span class="metric-card__label">QR</span>
        <strong class="metric-card__value">@qrCount</strong>
        <span class="metric-card__meta">Số lượt phát đến từ kênh quét QR tại điểm dừng.</span>
    </article>
</section>

<section class="page-grid page-section">
    <article class="card-surface card-surface--accent">
        <div class="section-heading">
            <div class="headline-stack">
                <span class="section-kicker">Filter</span>
                <h2>Bộ lọc dữ liệu</h2>
                <p class="section-caption">Khoanh vùng nhanh theo nguồn phát để so sánh hành vi sử dụng.</p>
            </div>
        </div>

        <form method="get" class="stack-gap">
            <div>
                <label class="form-label" for="source">Nguồn phát</label>
                <select id="source" name="source" class="form-select">
                    <option value="" selected="@(string.IsNullOrWhiteSpace(currentSource) ? "selected" : null)">Tất cả</option>
                    <option value="manual" selected="@(currentSource == "manual" ? "selected" : null)">Thủ công</option>
                    <option value="gps" selected="@(currentSource == "gps" ? "selected" : null)">GPS</option>
                    <option value="qr" selected="@(currentSource == "qr" ? "selected" : null)">QR</option>
                </select>
            </div>
            <div class="page-actions">
                <button type="submit" class="btn btn-primary">Áp dụng</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Xóa lọc</a>
            </div>
        </form>
    </article>

    <article class="card-surface">
        <div class="section-heading">
            <div class="headline-stack">
                <span class="section-kicker">Ranking</span>
                <h2>Top POI</h2>
                <p class="section-caption">Các điểm đang được phát nhiều nhất trong phạm vi dữ liệu hiện tại.</p>
            </div>
        </div>

        @if (!topPois.Any())
        {
            <div class="empty-state">
                <p>Chưa có dữ liệu.</p>
            </div>
        }
        else
        {
            <div class="list-stack">
                @foreach (var item in topPois)
                {
                    <div class="list-row">
                        <div class="list-row__content">
                            <strong>@item.PoiName</strong>
                            <p>POI #@item.PoiId</p>
                        </div>
                        <span class="soft-pill">@item.Count lượt</span>
                    </div>
                }
            </div>
        }
    </article>
</section>

<section class="card-surface page-section">
    <div class="section-heading">
        <div class="headline-stack">
            <span class="section-kicker">Realtime</span>
            <h2>Chi tiết lượt nghe</h2>
            <p class="section-caption">Bảng phát sinh mới nhất để kiểm tra trạng thái live giữa app và web.</p>
        </div>
    </div>

    @if (!items.Any())
    {
        <div class="empty-state">
            <p>Không có dữ liệu.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table data-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>POI</th>
                        <th>User</th>
                        <th>Ngôn ngữ</th>
                        <th>Nguồn</th>
                        <th>Chế độ</th>
                        <th>Thời gian</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in items)
                {
                    <tr>
                        <td>
                            <div class="table-title">@item.PoiName</div>
                            <div class="table-meta">#@item.PoiId</div>
                        </td>
                        <td><span class="soft-pill">@(string.IsNullOrWhiteSpace(item.UserKey) ? "anonymous" : item.UserKey)</span></td>
                        <td><span class="lang-pill">@item.Language.ToUpperInvariant()</span></td>
                        <td><span class="status-pill status-pill--info">@MapSource(item.TriggerSource)</span></td>
                        <td>@item.Mode.ToUpperInvariant()</td>
                        <td>@item.PlayedAt.ToString("dd/MM/yyyy HH:mm:ss")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>

@section Scripts {
    <script>
        (() => {
            const header = document.querySelector(".page-header.page-section");
            if (!header) {
                return;
            }

            let statusEl = document.getElementById("history-live-status");
            if (!statusEl) {
                const actions = document.createElement("div");
                actions.className = "page-actions";

                statusEl = document.createElement("span");
                statusEl.id = "history-live-status";
                statusEl.className = "soft-pill soft-pill--neutral";
                actions.appendChild(statusEl);
                header.appendChild(actions);
            }

            const source = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(currentSource));
            let lastItemId = @latestItemId;

            const setStatus = (text) => {
                statusEl.textContent = text;
            };

            const poll = async () => {
                try {
                    const query = new URLSearchParams({ top: "1" });
                    if (source) {
                        query.set("source", source);
                    }

                    const response = await fetch(`/api/narration-histories?${query.toString()}`, {
                        cache: "no-store",
                        headers: {
                            "X-Requested-With": "XMLHttpRequest"
                        }
                    });

                    if (!response.ok) {
                        throw new Error("fetch_failed");
                    }

                    const data = await response.json();
                    const newestId = Array.isArray(data) && data.length > 0
                        ? Number(data[0].id || 0)
                        : 0;

                    if (newestId !== lastItemId) {
                        setStatus("Có lượt nghe mới, đang cập nhật...");
                        window.location.reload();
                        return;
                    }

                    setStatus("Đang theo dõi realtime App/Web");
                } catch {
                    setStatus("Mất kết nối realtime, đang giữ dữ liệu hiện tại");
                }
            };

            setStatus("Đang theo dõi realtime App/Web");
            window.setInterval(poll, 5000);
        })();
    </script>
}

@functions {
    private static string MapSource(string source) =>
        source?.Trim().ToLowerInvariant() switch
        {
            "gps" => "GPS",
            "auto" => "GPS",
            "qr" => "QR",
            "manual" => "Thủ công",
            _ => "Khác"
        };
}
