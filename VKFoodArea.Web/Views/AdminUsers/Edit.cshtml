@model VKFoodArea.Web.ViewModels.AdminUserFormViewModel
@{
    ViewData["Title"] = "Sua admin";
}

<section class="page-header page-section">
    <div>
        <h2>Sua tai khoan CMS</h2>
    </div>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">Quay lai</a>
    </div>
</section>

<form asp-action="Edit" asp-route-id="@Model.Id" method="post">
    <partial name="_Form" model="Model" />
    <div class="page-actions page-section">
        <button type="submit" class="btn btn-primary">Luu thay doi</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Huy</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
