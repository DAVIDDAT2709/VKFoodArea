@model IEnumerable<VKFoodArea.Web.Models.AdminUser>
@{
    ViewData["Title"] = "Quản trị viên";
    var users = Model.ToList();
    var activeCount = users.Count(x => x.IsActive);
}

<section class="page-header page-section">
    <div>
        <h2>Quản trị viên</h2>
    </div>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary">Thêm admin</a>
    </div>
</section>

<section class="metrics-grid page-section">
    <article class="metric-card metric-card--blue">
        <span class="metric-card__label">Tổng admin</span>
        <strong class="metric-card__value">@users.Count</strong>
    </article>
    <article class="metric-card metric-card--green">
        <span class="metric-card__label">Đang hoạt động</span>
        <strong class="metric-card__value">@activeCount</strong>
    </article>
    <article class="metric-card metric-card--red">
        <span class="metric-card__label">Đang khóa</span>
        <strong class="metric-card__value">@(users.Count - activeCount)</strong>
    </article>
</section>

<section class="card-surface page-section">
    @if (!users.Any())
    {
        <div class="empty-state">
            <p>Chưa có tài khoản admin.</p>
        </div>
    }
    else
    {
        <div class="section-heading">
            <h2>Danh sách tài khoản</h2>
        </div>

        <div class="table-responsive">
            <table class="table data-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Tài khoản</th>
                        <th>Tên hiển thị</th>
                        <th>Quyền</th>
                        <th>Trạng thái</th>
                        <th>Đăng nhập gần nhất</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in users)
                {
                    <tr>
                        <td>
                            <div class="table-title">@item.Username</div>
                        </td>
                        <td>@item.FullName</td>
                        <td><span class="soft-pill soft-pill--neutral">@item.Role</span></td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="status-pill status-pill--success">Đang hoạt động</span>
                            }
                            else
                            {
                                <span class="status-pill status-pill--muted">Đang khóa</span>
                            }
                        </td>
                        <td>@(item.LastLoginAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                        <td>
                            <div class="table-actions">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Sửa</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Xóa</a>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>
