@model IEnumerable<VKFoodArea.Web.Models.AdminUser>
@{
    ViewData["Title"] = "Quan ly admin";
    var users = Model.ToList();
}

<section class="page-header page-section">
    <div>
        <h2>Quan ly tai khoan CMS</h2>
    </div>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary">Them admin</a>
    </div>
</section>

<section class="card-surface page-section">
    @if (!users.Any())
    {
        <div class="empty-state">
            <p>Chua co tai khoan admin.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table data-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Tai khoan</th>
                        <th>Ten hien thi</th>
                        <th>Quyen</th>
                        <th>Trang thai</th>
                        <th>Dang nhap gan nhat</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in users)
                {
                    <tr>
                        <td>
                            <div class="table-title">@item.Username</div>
                        </td>
                        <td>@item.FullName</td>
                        <td><span class="soft-pill">@item.Role</span></td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="status-pill status-pill--success">Active</span>
                            }
                            else
                            {
                                <span class="status-pill status-pill--muted">Locked</span>
                            }
                        </td>
                        <td>@(item.LastLoginAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                        <td>
                            <div class="table-actions">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Sua</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Xoa</a>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>
