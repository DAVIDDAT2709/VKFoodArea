@model VKFoodArea.Web.Models.AdminUser
@{
    ViewData["Title"] = "Xóa admin";
}

<section class="page-header page-section">
    <div>
        <h2>Xóa tài khoản admin</h2>
    </div>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">Quay lại</a>
    </div>
</section>

<section class="delete-grid page-section">
    <article class="card-surface">
        <div class="section-heading">
            <h2>@Model.Username</h2>
        </div>
        <div class="summary-list">
            <div class="summary-row">
                <span>Tên hiển thị</span>
                <strong>@Model.FullName</strong>
            </div>
            <div class="summary-row">
                <span>Quyền</span>
                <strong>@Model.Role</strong>
            </div>
            <div class="summary-row">
                <span>Trạng thái</span>
                <strong>@(Model.IsActive ? "Đang hoạt động" : "Đang khóa")</strong>
            </div>
        </div>
    </article>

    <aside class="warning-panel">
        <h3>Xác nhận xóa</h3>
        <p>Thao tác này sẽ xóa tài khoản quản trị khỏi hệ thống.</p>
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="page-actions">
            <button type="submit" class="btn btn-danger">Xóa admin</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
        </form>
    </aside>
</section>
