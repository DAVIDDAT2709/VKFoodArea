@model VKFoodArea.Web.ViewModels.TourIndexViewModel
@{
    ViewData["Title"] = "Quan ly tour";
    var tours = Model.Items.Items;
}

<section class="page-header page-section">
    <div>
        <h2>Danh sach tour</h2>
    </div>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary">Tao tour moi</a>
    </div>
</section>

<section class="card-surface page-section">
    @if (!tours.Any())
    {
        <div class="empty-state">
            <p>Chua co tour nao.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table data-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Tour</th>
                        <th>Mo ta</th>
                        <th>So stop</th>
                        <th>Trang thai</th>
                        <th class="text-end">Thao tac</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in tours)
                    {
                        <tr>
                            <td>
                                <div class="table-title">@item.Name</div>
                            </td>
                            <td>@item.Description</td>
                            <td>@item.Stops.OrderBy(x => x.DisplayOrder).Count()</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="status-pill status-pill--success">Dang hoat dong</span>
                                }
                                else
                                {
                                    <span class="status-pill status-pill--muted">Dang an</span>
                                }
                            </td>
                            <td>
                                <div class="table-actions justify-content-end">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm">Sua</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">Xoa</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <partial name="_Pagination"
                 model="@(VKFoodArea.Web.ViewModels.PaginationViewModel.From(Model.Items))" />
    }
</section>
