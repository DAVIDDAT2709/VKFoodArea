@model VKFoodArea.Web.ViewModels.TourFormViewModel
@{
    ViewData["Title"] = "Cập nhật tour";
}

<section class="page-header page-section">
    <div>
        <h2>Cập nhật tour</h2>
    </div>
</section>

<form asp-action="Edit" method="post" class="stack-gap page-section">
    <input type="hidden" asp-for="Id" />
    <partial name="_Form" model="Model" />

    <div class="page-actions">
        <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Quay lại danh sách</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
