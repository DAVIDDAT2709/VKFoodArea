@model VKFoodArea.Web.Models.Tour
@{
    ViewData["Title"] = "Xoa tour";
}

<section class="page-header page-section">
    <div>
        <h2>Xoa tour</h2>
    </div>
</section>

<section class="card-surface page-section">
    <div class="delete-grid">
        <div>
            <h3>@Model.Name</h3>
            <div class="list-stack">
                <div class="list-row">
                    <div class="list-row__content">
                        <strong>Mo ta</strong>
                        <p>@Model.Description</p>
                    </div>
                </div>
                <div class="list-row">
                    <div class="list-row__content">
                        <strong>So stop</strong>
                        <p>@Model.Stops.Count</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="warning-panel">
            <h3>Xac nhan xoa</h3>
            <div class="page-actions">
                <a asp-action="Index" class="btn btn-outline-secondary">Huy</a>
                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger">Xoa tour</button>
                </form>
            </div>
        </div>
    </div>
</section>
